{
  "info": {
    "name": "Threadly API - Quick Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Auth - Signup (brand)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"brand@example.com\",\n  \"password\": \"Password123\",\n  \"type\": \"BRAND\",\n  \"brandFullName\": \"My Brand Company\",\n  \"companyLocation\": \"Lagos, Nigeria\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth","signup"] }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"brand@example.com\",\n  \"password\": \"Password123\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
      }
    },
    {
      "name": "Follow a user",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{ \"targetId\": \"<target-user-id>\" }" },
        "url": { "raw": "{{baseUrl}}/follows", "host": ["{{baseUrl}}"], "path": ["follows"] }
      }
    },
    {
      "name": "Unfollow a user",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/follows/<target-id>", "host": ["{{baseUrl}}"], "path": ["follows","<target-id>"] }
      }
    },
    {
      "name": "Toggle like on a post",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/posts/<postId>/likes", "host": ["{{baseUrl}}"], "path": ["posts","<postId>","likes"] }
      }
    },
    {
      "name": "Get users who liked a post",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/posts/<postId>/likes", "host": ["{{baseUrl}}"], "path": ["posts","<postId>","likes"] }
      }
    },
    {
      "name": "Toggle like on a comment",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "{{baseUrl}}/posts/<postId>/comments/<commentId>/reactions/like", "host": ["{{baseUrl}}"], "path": ["posts","<postId>","comments","<commentId>","reactions","like"] }
      }
    },
    {
      "name": "Get users who liked a comment",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/posts/<postId>/comments/<commentId>/reactions", "host": ["{{baseUrl}}"], "path": ["posts","<postId>","comments","<commentId>","reactions"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ]
}
