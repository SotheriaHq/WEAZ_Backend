        },
        "url": {"raw": "http://localhost:3000/auth/login", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth", "login"]}
      }
    },
    {
      "name": "Verify Email by Code",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john@example.com\",\n  \"code\": \"ABC123\"\n}"
        },
        "url": {"raw": "http://localhost:3000/auth/verify-email-code", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth", "verify-email-code"]}
      }
    },
    {
      "name": "Verify Email by Link",
      "request": {
        "method": "GET",
        "header": [],
        "url": {"raw": "http://localhost:3000/auth/verify-email?userId=<USER_ID>&code=<CODE>", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth", "verify-email"], "query": [{"key": "userId", "value": "<USER_ID>"}, {"key": "code", "value": "<CODE>"}]}
      }
    },
    {
      "name": "Get All Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {"raw": "http://localhost:3000/auth/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth", "users"]}
      }
    },
    {
      "name": "Get Single User",
      "request": {
        "method": "GET",
        "header": [],
        "url": {"raw": "http://localhost:3000/auth/user/<USER_ID>", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["auth", "user", "<USER_ID>"]}
      }
    },
    {
