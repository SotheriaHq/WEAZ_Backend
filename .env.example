# Backend environment configuration
# Copy this file to `.env` and adjust values per environment.

APP_PORT=3040
APP_HOST=0.0.0.0
TRUST_PROXY=false

# Keep checkout callback parity with the web app in every environment.
# Desktop local testing should use localhost so email links open in the same browser:
#   WEB_APP_URL=http://localhost:3000
# Mobile-device testing may use a LAN IP only when the web dev server is bound to
# 0.0.0.0 and the device can reach that address.
WEB_APP_URL=http://localhost:3000
FRONTEND_PUBLIC_CHECKOUT_CALLBACK_URL=http://localhost:3000/bag/payment-return
WEB_APP_USE_HTTPS=false
WEB_APP_HOST=localhost
WEB_APP_PORT=3000

# Optional local HTTPS parity for the API itself.
APP_HTTPS_CERT_PATH=./certs/localhost.pem
APP_HTTPS_KEY_PATH=./certs/localhost-key.pem

# Use Paystack test keys in local/staging so the real hosted flow shape is identical everywhere.
PAYMENTS_MODE=live
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_CUSTOM_CARD_ENTRY_ENABLED=false
PAYSTACK_CARDHOLDER_NAME_MATCH_MODE=soft
# Keep legacy alias routes disabled. Canonical ingress is POST /webhooks/paystack.
PAYMENT_LEGACY_PAYSTACK_WEBHOOK_ALIASES_ENABLED=false
# Keep legacy Flutterwave alias route disabled. Canonical ingress is POST /webhooks/flutterwave.
PAYMENT_LEGACY_FLUTTERWAVE_WEBHOOK_ALIAS_ENABLED=false
# Keep legacy custom-order direct initialize helpers disabled.
PAYMENT_LEGACY_CUSTOM_ORDER_INIT_ENABLED=false
# Flutterwave webhook verification is supported, but checkout initialization is fail-closed in live mode.
FLUTTERWAVE_WEBHOOK_SECRET_HASH=replace_with_flutterwave_webhook_hash
REDIS_URL=redis://127.0.0.1:6379/0

# Payment rollout safety controls (phase 3/7)
PAYMENT_CANONICAL_SAVED_METHODS_ENABLED=false
PAYMENT_CANONICAL_SAVED_METHODS_CANARY_PERCENT=0
PAYMENT_CANONICAL_SAVED_METHODS_BACKFILL_ENABLED=true
# Keep this deterministic per environment (no user-level canary for card validation).
PAYMENT_VALIDATION_GATE_ENABLED=true
PAYMENT_SAVED_METHODS_SECRET=replace_with_high_entropy_secret
