  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdById String    @db.Uuid
  createdBy   User      @relation("AdminSlaConfigCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([area, isActive])
}

model AdminNotificationLog {
  id          String   @id @map("_id") @db.Uuid
  adminUserId String   @db.Uuid
  admin       User     @relation("AdminNotificationsSent", fields: [adminUserId], references: [id])
  targetType  String
  targetId    String?  @db.Uuid
  channel     String
  templateKey String?
  message     String?
  createdAt   DateTime @default(now())

  @@index([adminUserId, createdAt])
