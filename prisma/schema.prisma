// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String          @id @map("_id") @db.Uuid
  username              String          @unique
  role                  Role            @default(User)
  type                  UserType        @default(REGULAR)
  firstName             String
  lastName              String
  email                 String          @unique
  password              String
  phoneNumber           String?
  address               String?
  brandFullName         String?
  cacNumber             String?         @unique
  tin                   String?         @unique
  ceoNin                String?         @unique
  ceoFirstName          String?
  ceoLastName           String?
  companyLocation       String?
  brandDescription      String?
  brandCountry          String?
  brandState            String?
  brandCity             String?
  brandTags             String[]        @default([])
  brandBusinessType     String?
  socialInstagram       String?
  socialFacebook        String?
  socialTwitter         String?
  socialWebsite         String?
  profileImage          String?
  profileImageId        String?         @db.Uuid
  profileImageFile      FileUpload?     @relation("UserProfileImage", fields: [profileImageId], references: [id])
  bannerImage           String?
  bannerImageId         String?         @db.Uuid
  bannerImageFile       FileUpload?     @relation("UserBannerImage", fields: [bannerImageId], references: [id])
  industriNumber        String?         @unique
  profileVisibility     ProfileVisibility @default(UNLOCKED)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  refreshTokens         RefreshToken[]
  fileUploads           FileUpload[]    @relation("UserFiles")
  posts                 Post[]
  comments              Comment[]
  threads               Thread[]
  commentsV2            CommentV2[]
  commentV2Threads      CommentV2Thread[]
  isEmailVerified       Boolean         @default(false)
  emailVerificationCode String?         @unique
  isActive              String          @default("Active")
  notificationSettings  Json?           // Stores user preferences { security: { login: true }, engagement: { threads: true } }

  // Relations for new social models
  followerFollows         Follow[]                        @relation("followerFollows")
  followingFollows        Follow[]                        @relation("followingFollows")

  // Brand Patching (Mutual)
  sentPatchRequests       BrandPatch[]                    @relation("SentPatchRequests")
  receivedPatchRequests   BrandPatch[]                    @relation("ReceivedPatchRequests")

  // Contributions
  contributionRequests    ContributionRequest[]           @relation("UserContributionRequests")

  collections             Collection[]
  collectionReactions     CollectionReaction[]
  collectionComments      CollectionComment[]
  commentReactions        CommentReaction[]
  collectionCollabsMade   CollectionCollab[]              @relation("UserCollectionCollabs")
  patchConnectionsMade    PatchConnection[]               @relation("PatchRequester")
  patchConnectionsReceived PatchConnection[]              @relation("PatchTarget")
  savedItems              SavedItem[]                     @relation("UserSavedItems")
  views                   View[]
  notificationsReceived   Notification[]                  @relation("UserNotificationsReceived")
  notificationsActed      Notification[]                  @relation("UserNotificationsActed")
  presignedUploads        PresignedUpload[]
  CollectionMediaReaction CollectionMediaReaction[]
  // Access to private collections (viewer side)
  collectionAccesses      CollectionAccess[]
  // PHASE 1: Category suggestions
  proposedSuggestions     CollectionCategorySuggestion[]  @relation("ProposedCategorySuggestions")
  decidedSuggestions      CollectionCategorySuggestion[]  @relation("DecidedCategorySuggestions")
  // Brand Relation
  brand                   Brand?                          @relation("BrandOwner")

  // Orders as buyer
  ordersAsBuyer           Order[]                         @relation("OrderBuyer")
  sizeFitProfile          UserSizeFitProfile?
  sizeFitSharesOwned      UserSizeFitShare[]             @relation("SizeFitOwnerShares")
  sizeFitSharesReceived   UserSizeFitShare[]             @relation("SizeFitViewerShares")
  sizeFitShareRequestsMade UserSizeFitShare[]            @relation("SizeFitRequestedBy")
  sizeFitRevisions        UserSizeFitRevision[]          @relation("SizeFitRevisionAuthor")

  // Idempotency keys (safe retries for POST requests)
  idempotencyKeys         IdempotencyKey[]
  collectionDraftSessions CollectionDraftSession[]
  collectionBulkUploadJobs CollectionBulkUploadJob[]
}

model FileUpload {
  id           String   @id @map("_id") @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation("UserFiles", fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  fileName     String
  s3Key        String   @unique
  s3Url        String
  fileType     FileType
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations for profile images
  profileUsers User[] @relation("UserProfileImage")

  // Relations for posts
  posts      Post[] @relation("PostImages")
  postVideos Post[] @relation("PostVideos")

  // Relation to collection media
  collectionMedias CollectionMedia[] @relation("FileUpload_to_CollectionMedia")
  bannerUsers      User[]            @relation("UserBannerImage")
}

model Post {
  id            String       @id @map("_id") @db.Uuid
  userId        String       @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String?
  imageIds      String[]     @db.Uuid
  images        FileUpload[] @relation("PostImages")
  videoId       String?      @db.Uuid
  video         FileUpload?  @relation("PostVideos", fields: [videoId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  comments      Comment[]
  threads       Thread[]
  threadsCount  Int          @default(0) @map("likesCount")
  commentsCount Int          @default(0)
}

model Comment {
  id        String   @id @map("_id") @db.Uuid
  postId    String   @db.Uuid
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id         String    @id @map("_id") @db.Uuid
  tokenHash  String    @unique
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt])
}

enum Role {
  SuperAdmin
  Admin
  User
}

enum UserType {
  BRAND
  REGULAR
}

enum ProfileVisibility {
  UNLOCKED
  LOCKED
}

enum SizeFitVisibility {
  PUBLIC
  PRIVATE
}

enum SizeFitSharePolicy {
  OWNER_ONLY
  REQUIRE_PERMISSION
  ALLOW_ANYONE
}

enum SizeFitShareStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum FileType {
  PROFILE_IMAGE
  BANNER_IMAGE
  POST_IMAGE
  POST_VIDEO
  DOCUMENT
}

enum PresignStatus {
  PENDING
  READY
  USED
  EXPIRED
}

enum TagEntityType {
  COLLECTION
  PRODUCT
  BRAND
  USER_BRAND
}

model Thread {
  id            String   @id @map("_id") @db.Uuid
  postId        String   @db.Uuid
  userId        String   @db.Uuid
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId String?  @unique
  createdAt     DateTime @default(now())

  @@unique([postId, userId]) // Prevent duplicate threads
  @@map("Like")
}

enum ReactionType {
  THREAD
  DISLIKE
}

enum NotificationType {
  SIGNUP
  LOGIN
  COLLECTION_UPLOAD
  PRODUCT_UPLOAD
  COLLECTION_DELETED
  THREAD
  COMMENT
  PATCH
  FOLLOW
  TAG_MENTION
  LOGOUT
  LOGOUT_ALL
  // Private collection access workflow
  PRIVATE_ACCESS_REQUESTED
  PRIVATE_ACCESS_APPROVED
  PRIVATE_ACCESS_REJECTED
  PRIVATE_ACCESS_REVOKED
  
  // Brand Patching
  BRAND_PATCH_REQUEST
  BRAND_PATCH_ACCEPTED
  BRAND_PATCH_REJECTED

  // Orders
  ORDER_PLACED
  ORDER_STATUS_UPDATED

  // Contributions
  CONTRIBUTION_REQUEST
  CONTRIBUTION_ACCEPTED
  CONTRIBUTION_REJECTED

  // Size fit reminders and sharing
  SIZE_FIT_UPDATE_REMINDER
  SIZE_FIT_SHARED
  SIZE_FIT_SHARE_REQUEST
  SIZE_FIT_SHARE_APPROVED
  SIZE_FIT_SHARE_REJECTED
  SIZE_FIT_RESHARED
}

// ====== Comment V2 (unified for posts, collections, and collection media) ======

enum CommentTarget {
  POST
  COLLECTION
  COLLECTION_MEDIA
}

model CommentV2 {
  id               String          @id @map("_id") @db.Uuid
  targetType       CommentTarget
  targetId         String          @db.Uuid
  userId           String          @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId         String?         @db.Uuid
  parent           CommentV2?      @relation("CommentV2Children", fields: [parentId], references: [id])
  children         CommentV2[]     @relation("CommentV2Children")
  depth            Int             @default(0)
  contentRaw       String
  contentSanitized String
  threadsCount     Int             @default(0) @map("likeCount")
  replyCount       Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?
  version          Int             @default(1)
  threads          CommentV2Thread[]

  @@index([targetType, targetId, createdAt])
  @@index([parentId, createdAt])
}

model CommentV2Thread {
  id        String    @id @map("_id") @db.Uuid
  commentId String    @db.Uuid
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  comment   CommentV2 @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("CommentV2Like")
}

model Follow {
  id          String   @id @map("_id") @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  follower    User     @relation("followerFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followingFollows", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Collection {
  id                           String                          @id @map("_id") @db.Uuid
  ownerId                      String                          @db.Uuid
  owner                        User                            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title                        String?
  description                  String?
  status                       CollectionStatus                @default(DRAFT)
  archivedFromStatus           CollectionStatus?
  visibility                   CollectionVisibility            @default(PUBLIC)
  type                         CollectionType                  @default(EVERYBODY)
  categoryId                   String?                         @db.Uuid
  category                     CollectionCategory?             @relation(fields: [categoryId], references: [id])
  coverMediaId                 String?                         @db.Uuid
  coverMedia                   CollectionMedia?                @relation("CollectionCoverMedia", fields: [coverMediaId], references: [id])
  deletedAt                    DateTime?
  deleteExpiresAt              DateTime?
  lastActivityAt               DateTime?
  draftVersion                 Int                             @default(0)
  // PHASE 1: Pending category support for draft collections
  pendingCategorySuggestionId  String?                         @db.Uuid
  pendingCategorySuggestion    CollectionCategorySuggestion?   @relation(fields: [pendingCategorySuggestionId], references: [id], onDelete: SetNull)
  draftReason                  String?                         // Enum-like: "AWAITING_CATEGORY_APPROVAL", "USER_SAVED", "CATEGORY_REJECTED", "UPLOAD_INCOMPLETE"
  pendingCategoryName          String?                         // Human-readable name for UI display
  originalSuggestionId         String?                         @db.Uuid // Audit trail - maintains reference even after approval/rejection
  minPrice                     Float?
  maxPrice                     Float?
  isAvailableInStore           Boolean                         @default(false)
  tags                         String[]                        @default([])
  // Optional sale/discount fields
  saleMinPrice                 Float?
  saleMaxPrice                 Float?
  saleStartAt                  DateTime?
  saleEndAt                    DateTime?
  createdAt                    DateTime                        @default(now())
  updatedAt                    DateTime                        @updatedAt
  threadsCount                 Int                             @default(0) @map("likesCount")
  dislikesCount                Int                             @default(0)
  commentsCount                Int                             @default(0)
  collectionCollabsCount       Int                             @default(0) @map("patchesCount")
  viewsCount                   Int                             @default(0)
  medias                       CollectionMedia[]               @relation("Collection_to_Media")
  reactions                    CollectionReaction[]
  comments                     CollectionComment[]
  collectionCollabs            CollectionCollab[]              @relation("Collection_to_Collab")
  views                        View[]                          @relation("Collection_to_View")
  // Access approvals for private collections
  accesses                     CollectionAccess[]
  
  // Contributions
  contributionRequests         ContributionRequest[]           @relation("CollectionContributionRequests")
  
  // E-commerce products (multi-collection membership)
  products                     CollectionProduct[]
  // Primary collection link (compatibility)
  primaryProducts              Product[]                       @relation("PrimaryCollection")
  draftSessions                CollectionDraftSession[]
  bulkUploadJobs               CollectionBulkUploadJob[]

  @@index([status, createdAt])
  @@index([status, collectionCollabsCount])
  @@index([status, visibility, createdAt])
  @@index([status, pendingCategorySuggestionId]) // PHASE 1: Fast lookup of drafts waiting for category approval
  @@index([ownerId, status, createdAt]) // PHASE 1: User's draft management
  @@index([deletedAt])
  @@index([deleteExpiresAt])
  @@index([lastActivityAt])
}

enum BulkUploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum BulkUploadRowStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  SKIPPED
}

model CollectionDraftSession {
  id              String     @id @map("_id") @db.Uuid
  collectionId    String     @db.Uuid
  ownerId         String     @db.Uuid
  sessionToken    String     @unique
  deviceName      String?
  deviceType      String?
  startedAt       DateTime   @default(now())
  lastHeartbeatAt DateTime   @default(now())
  expiresAt       DateTime
  isActive        Boolean    @default(true)

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  owner           User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([collectionId, isActive])
  @@index([ownerId])
  @@index([expiresAt])
}

model CollectionBulkUploadJob {
  id            String           @id @map("_id") @db.Uuid
  collectionId  String           @db.Uuid
  ownerId       String           @db.Uuid
  status        BulkUploadStatus @default(PENDING)
  mode          String?
  totalRows     Int              @default(0)
  processedRows Int              @default(0)
  successRows   Int              @default(0)
  failedRows    Int              @default(0)
  errorSummary  Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  completedAt   DateTime?

  collection    Collection       @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rows          CollectionBulkUploadRow[]

  @@index([collectionId, createdAt])
  @@index([ownerId, createdAt])
  @@index([status, createdAt])
}

model CollectionBulkUploadRow {
  id              String              @id @map("_id") @db.Uuid
  jobId           String              @db.Uuid
  rowIndex        Int
  rowId           String?
  status          BulkUploadRowStatus @default(PENDING)
  errorMessage    String?
  payload         Json?
  createdProductId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  job             CollectionBulkUploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, rowIndex])
  @@unique([jobId, rowId])
  @@index([jobId, status])
  @@index([rowId])
}

model CollectionProduct {
  id           String   @id @map("_id") @db.Uuid
  collectionId String   @db.Uuid
  productId    String   @db.Uuid
  orderIndex   Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([productId])
  @@index([collectionId, orderIndex])
}

enum CollectionStatus {
  DRAFT // Created but files not uploaded
  PUBLISHED // Fully published and visible
  ARCHIVED // Hidden from public view
}

enum CollectionVisibility {
  PUBLIC
  PRIVATE
}

enum CollectionType {
  MALE
  FEMALE
  EVERYBODY
}

model CollectionCategory {
  id                      String                          @id @map("_id") @db.Uuid
  slug                    String                          @unique
  name                    String
  description             String?
  isActive                Boolean                         @default(true)
  order                   Int                             @default(0)
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  collections             Collection[]
  // PHASE 1: Approved suggestions that created this category
  approvedSuggestions     CollectionCategorySuggestion[]

  @@index([isActive, order])
}

// ===== Category Suggestions (Phase 6) =====

enum CategorySuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model CollectionCategorySuggestion {
  id                     String                    @id @map("_id") @db.Uuid
  name                   String
  slug                   String                    @unique
  description            String?
  status                 CategorySuggestionStatus  @default(PENDING)
  proposedByUserId       String                    @db.Uuid
  proposedByUser         User                      @relation("ProposedCategorySuggestions", fields: [proposedByUserId], references: [id], onDelete: Cascade)
  decisionByUserId       String?                   @db.Uuid
  decisionByUser         User?                     @relation("DecidedCategorySuggestions", fields: [decisionByUserId], references: [id])
  rejectionReason        String?
  approvedCategoryId     String?                   @db.Uuid
  approvedCategory       CollectionCategory?       @relation(fields: [approvedCategoryId], references: [id])
  decidedAt              DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  // PHASE 1: Relation to draft collections waiting for this suggestion
  pendingCollections     Collection[]

  @@index([status, createdAt])
  @@index([proposedByUserId, createdAt])
  @@index([slug, status]) // PHASE 1: Duplicate detection and fast lookup
}

model CollectionAccess {
  id           String      @id @map("_id") @db.Uuid
  collectionId String      @db.Uuid
  viewerId     String      @db.Uuid
  state        AccessState @default(PENDING)
  grantedBy    String?     @db.Uuid
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  viewer       User        @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([collectionId, viewerId])
  @@index([collectionId, state])
  @@index([viewerId, state])
}

enum AccessState {
  PENDING
  APPROVED
  REVOKED
}

model CollectionMedia {
  id                      String                    @id @map("_id") @db.Uuid
  collectionId            String                    @db.Uuid
  collection              Collection                @relation("Collection_to_Media", fields: [collectionId], references: [id], onDelete: Cascade)
  fileUploadId            String                    @db.Uuid
  file                    FileUpload                @relation("FileUpload_to_CollectionMedia", fields: [fileUploadId], references: [id])
  orderIndex              Int                       @default(0)
  mediaType               FileType
  threadsCount            Int                       @default(0) @map("likesCount")
  CollectionMediaReaction CollectionMediaReaction[]
  commentsCount           Int                       @default(0)
  // inverse relation for cover usage
  coverOf                Collection[]              @relation("CollectionCoverMedia")
}

model CollectionReaction {
  id            String       @id @map("_id") @db.Uuid
  collectionId  String       @db.Uuid
  userId        String       @db.Uuid
  type          ReactionType
  collection    Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId String?
  createdAt     DateTime     @default(now())

  @@unique([collectionId, userId])
  @@index([collectionId])
}

model CollectionComment {
  id           String            @id @map("_id") @db.Uuid
  collectionId String            @db.Uuid
  userId       String            @db.Uuid
  content      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  collection   Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions    CommentReaction[]
}

model CommentReaction {
  id        String            @id @map("_id") @db.Uuid
  commentId String            @db.Uuid
  userId    String            @db.Uuid
  type      ReactionType
  comment   CollectionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@unique([commentId, userId])
}

// Collection collaboration between brands (formerly CollectionPatch)
model CollectionCollab {
  id              String     @id @map("_id") @db.Uuid
  collectionId    String     @db.Uuid
  patchingBrandId String     @db.Uuid
  weight          Int        @default(1)
  createdAt       DateTime   @default(now())
  collection      Collection @relation("Collection_to_Collab", fields: [collectionId], references: [id], onDelete: Cascade)
  patchingBrand   User       @relation("UserCollectionCollabs", fields: [patchingBrandId], references: [id], onDelete: Cascade)

  @@map("CollectionPatch")
}

// New unified PatchConnection model for user-to-brand and brand-to-brand patching
model PatchConnection {
  id          String      @id @map("_id") @db.Uuid
  requesterId String      @db.Uuid
  targetId    String      @db.Uuid
  status      PatchStatus @default(ACCEPTED) // Default to ACCEPTED for user-to-brand
  mode        PatchMode   @default(USER_TO_BRAND) // Default to USER_TO_BRAND
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  requester   User        @relation("PatchRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target      User        @relation("PatchTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
  @@index([requesterId, status])
}

enum PatchMode {
  USER_TO_BRAND
  BRAND_TO_BRAND
}

model View {
  id           String     @id @map("_id") @db.Uuid
  collectionId String     @db.Uuid
  viewerId     String?    @db.Uuid
  ipHash       String?
  createdAt    DateTime   @default(now())
  collection   Collection @relation("Collection_to_View", fields: [collectionId], references: [id], onDelete: Cascade)
  viewer       User?      @relation(fields: [viewerId], references: [id])

  @@index([collectionId])
}

model Notification {
  id          String           @id @map("_id") @db.Uuid
  recipientId String           @db.Uuid
  actorId     String?          @db.Uuid
  type        NotificationType
  payload     Json?
  html        String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  recipient   User             @relation("UserNotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?            @relation("UserNotificationsActed", fields: [actorId], references: [id])

  @@index([recipientId])
  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
}

model UserSizeFitProfile {
  id                    String              @id @map("_id") @db.Uuid
  userId                String              @unique @db.Uuid
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  visibility            SizeFitVisibility   @default(PRIVATE)
  sharePolicy           SizeFitSharePolicy  @default(REQUIRE_PERMISSION)
  notifyOnShare         Boolean             @default(true)
  requireUpdateEveryDays Int                @default(14)
  measurements          Json?
  notes                 String?
  lastUpdatedAt         DateTime?
  nextReminderAt        DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  revisions             UserSizeFitRevision[]
  shares                UserSizeFitShare[]

  @@index([nextReminderAt])
  @@index([visibility, sharePolicy])
}

model UserSizeFitRevision {
  id          String             @id @map("_id") @db.Uuid
  profileId   String             @db.Uuid
  profile     UserSizeFitProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  version     Int
  measurements Json
  changedKeys String[]           @default([])
  createdById String             @db.Uuid
  createdBy   User               @relation("SizeFitRevisionAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  @@unique([profileId, version])
  @@index([createdById, createdAt])
}

model UserSizeFitShare {
  id            String             @id @map("_id") @db.Uuid
  profileId     String             @db.Uuid
  profile       UserSizeFitProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ownerId       String             @db.Uuid
  owner         User               @relation("SizeFitOwnerShares", fields: [ownerId], references: [id], onDelete: Cascade)
  viewerId      String             @db.Uuid
  viewer        User               @relation("SizeFitViewerShares", fields: [viewerId], references: [id], onDelete: Cascade)
  requestedById String?            @db.Uuid
  requestedBy   User?              @relation("SizeFitRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  status        SizeFitShareStatus @default(PENDING)
  canReshare    Boolean            @default(false)
  note          String?
  respondedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([profileId, viewerId])
  @@index([ownerId, status, createdAt])
  @@index([viewerId, status, createdAt])
  @@index([requestedById, status, createdAt])
}

model PresignedUpload {
  id           String        @id @map("_id") @db.Uuid
  userId       String        @db.Uuid
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId String?       @db.Uuid
  orderIndex   Int?
  originalName String
  contentType  String
  fileType     FileType
  s3Key        String        @unique
  size         Int?
  status       PresignStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ===== Threads Analytics & Moderation =====

enum ContentTarget {
  POST
  COLLECTION
}

model DailyThreadAggregate {
  id          String        @id @default(uuid())
  contentId   String
  contentType ContentTarget
  date        DateTime
  count       Int           @default(0)

  @@unique([contentType, contentId, date])
  @@index([contentType, contentId])
  @@map("DailyLikeAggregate")
}

model QuarantinedThread {
  id          String        @id @default(uuid())
  userId      String
  contentId   String
  contentType ContentTarget
  reason      String?
  createdAt   DateTime      @default(now())

  @@index([userId, contentType, contentId])
  @@map("QuarantinedLike")
}

model CollectionMediaReaction {
  id                String          @id @map("_id") @db.Uuid
  collectionMediaId String          @db.Uuid
  userId            String          @db.Uuid
  type              ReactionType
  media             CollectionMedia @relation(fields: [collectionMediaId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId     String?
  createdAt         DateTime        @default(now())

  @@unique([collectionMediaId, userId])
  @@index([collectionMediaId])
}

