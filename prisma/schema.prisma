  user      User      @relation("PasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([tokenHash])
}

model AccountReactivationRequest {
  id            String                    @id @map("_id") @db.Uuid
  userId        String                    @db.Uuid
  user          User                      @relation("UserReactivationRequests", fields: [userId], references: [id], onDelete: Cascade)
  emailSnapshot String
  reason        String
  status        ReactivationRequestStatus @default(PENDING)
  adminNote     String?
  reviewedById  String?                   @db.Uuid
  reviewedBy    User?                     @relation("AdminReviewedReactivationRequests", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
}

// ===== Product Reviews =====

enum ProductReviewStatus {
  PUBLISHED
  HIDDEN_BY_ADMIN
  DELETED_BY_USER
}

enum ProductReviewReportReason {
  SPAM
  HARASSMENT
  HATE
  OFF_TOPIC
  COUNTERFEIT
  MEDIA_POLICY
  OTHER
}

model ProductReview {
  id          String    @id @default(uuid()) @db.Uuid
  productId   String    @db.Uuid
  product     Product   @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  brandId     String    @db.Uuid
  brand       Brand     @relation("BrandProductReviews", fields: [brandId], references: [id], onDelete: Cascade)
  userId      String    @db.Uuid
  user        User      @relation("UserProductReviews", fields: [userId], references: [id], onDelete: Restrict)
  orderItemId String    @db.Uuid
  orderItem   OrderItem @relation("OrderItemProductReviews", fields: [orderItemId], references: [id], onDelete: Restrict)

  rating   Int
  title    String?
  content  String
  mediaIds String[] @default([])

  productNameSnapshot   String?
  thumbnailSnapshot     String?
  selectedSizeSnapshot  String?
  selectedColorSnapshot String?

  helpfulCount Int @default(0)
  reportCount  Int @default(0)

  brandReply          String?
  brandReplyAt        DateTime?
  brandReplyUpdatedAt DateTime?

  status          ProductReviewStatus @default(PUBLISHED)
  activeReviewKey String?             @default("ACTIVE")
  hiddenReason    String?
  hiddenAt        DateTime?
  hiddenByAdminId String?             @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?
  deletedAt DateTime?

  helpfulVotes ProductReviewHelpfulVote[]
  reports      ProductReviewReport[]

  @@unique([userId, productId, activeReviewKey])
  @@index([productId, status, createdAt])
  @@index([brandId, status, createdAt])
  @@index([orderItemId])
  @@index([userId, productId, status])
}

model ProductReviewHelpfulVote {
  id        String        @id @default(uuid()) @db.Uuid
  reviewId  String        @db.Uuid
  review    ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String        @db.Uuid
  user      User          @relation("UserReviewHelpfulVotes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([reviewId, userId])
  @@index([userId, createdAt])
}

model ProductReviewReport {
  id         String                    @id @default(uuid()) @db.Uuid
  reviewId   String                    @db.Uuid
  review     ProductReview             @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporterId String                    @db.Uuid
  reporter   User                      @relation("UserProductReviewReports", fields: [reporterId], references: [id], onDelete: Cascade)
  brandId    String?                   @db.Uuid
  reason     ProductReviewReportReason
  details    String?
  createdAt  DateTime                  @default(now())

  @@unique([reviewId, reporterId])
  @@index([reason, createdAt])
}

// ─── System Configuration (key-value, admin-managed) ─────────────────────────
model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?  @db.Uuid
  updatedBy   User?    @relation("SystemConfigUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("system_config")
}
