// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String          @id @map("_id") @db.Uuid
  username              String          @unique
  role                  Role            @default(User)
  type                  UserType        @default(REGULAR)
  firstName             String
  lastName              String
  email                 String          @unique
  password              String
  phoneNumber           String?
  address               String?
  brandFullName         String?
  cacNumber             String?         @unique
  tin                   String?         @unique
  ceoNin                String?         @unique
  ceoFirstName          String?
  ceoLastName           String?
  companyLocation       String?
  brandDescription      String?
  brandCountry          String?
  brandState            String?
  brandCity             String?
  brandTags             String[]        @default([])
  brandBusinessType     String?
  socialInstagram       String?
  socialFacebook        String?
  socialTwitter         String?
  socialWebsite         String?
  profileImage          String?
  profileImageId        String?         @db.Uuid
  profileImageFile      FileUpload?     @relation("UserProfileImage", fields: [profileImageId], references: [id])
  bannerImage           String?
  bannerImageId         String?         @db.Uuid
  bannerImageFile       FileUpload?     @relation("UserBannerImage", fields: [bannerImageId], references: [id])
  industriNumber        String?         @unique
  profileVisibility     ProfileVisibility @default(UNLOCKED)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  refreshTokens         RefreshToken[]
  fileUploads           FileUpload[]    @relation("UserFiles")
  posts                 Post[]
  comments              Comment[]
  threads               Thread[]
  commentsV2            CommentV2[]
  commentV2Threads      CommentV2Thread[]
  isEmailVerified       Boolean         @default(false)
  emailVerificationCode String?         @unique
  isActive              String          @default("Active")
  notificationSettings  Json?           // Stores user preferences { security: { login: true }, engagement: { threads: true } }

  // Admin Console fields
  status                UserStatus      @default(ACTIVE)
  adminSuspendedAt      DateTime?
  adminSuspendedReason  String?
  deactivatedAt         DateTime?
  deactivatedReason     String?
  mustResetPassword     Boolean         @default(false)
  authVersion           Int             @default(0)

  // Relations for new social models
  followerFollows         Follow[]                        @relation("followerFollows")
  followingFollows        Follow[]                        @relation("followingFollows")

  // Brand Patching (Mutual)
  sentPatchRequests       BrandPatch[]                    @relation("SentPatchRequests")
  receivedPatchRequests   BrandPatch[]                    @relation("ReceivedPatchRequests")

  // Contributions
  contributionRequests    ContributionRequest[]           @relation("UserContributionRequests")

  collections             Collection[]
  storeCollections        StoreCollection[]
  collectionReactions     CollectionReaction[]
  collectionComments      CollectionComment[]
  commentReactions        CommentReaction[]
  collectionCollabsMade   CollectionCollab[]              @relation("UserCollectionCollabs")
  patchConnectionsMade    PatchConnection[]               @relation("PatchRequester")
  patchConnectionsReceived PatchConnection[]              @relation("PatchTarget")
  savedItems              SavedItem[]                     @relation("UserSavedItems")
  views                   View[]
  notificationsReceived   Notification[]                  @relation("UserNotificationsReceived")
  notificationsActed      Notification[]                  @relation("UserNotificationsActed")
  presignedUploads        PresignedUpload[]
  CollectionMediaReaction CollectionMediaReaction[]
  // Access to private collections (viewer side)
  collectionAccesses      CollectionAccess[]
  // PHASE 1: Category suggestions
  proposedSuggestions     CollectionCategorySuggestion[]  @relation("ProposedCategorySuggestions")
  decidedSuggestions      CollectionCategorySuggestion[]  @relation("DecidedCategorySuggestions")
  // Brand Relation
  brand                   Brand?                          @relation("BrandOwner")

  // Orders as buyer
  ordersAsBuyer           Order[]                         @relation("OrderBuyer")
  sizeFitProfile          UserSizeFitProfile?
  sizeFitSharesOwned      UserSizeFitShare[]             @relation("SizeFitOwnerShares")
  sizeFitSharesReceived   UserSizeFitShare[]             @relation("SizeFitViewerShares")
  sizeFitShareRequestsMade UserSizeFitShare[]            @relation("SizeFitRequestedBy")
  sizeFitRevisions        UserSizeFitRevision[]          @relation("SizeFitRevisionAuthor")

  // Idempotency keys (safe retries for POST requests)
  idempotencyKeys         IdempotencyKey[]
  collectionDraftSessions CollectionDraftSession[]
  collectionBulkUploadJobs CollectionBulkUploadJob[]

  // Admin Console relations
  adminPermissionGrants     AdminPermissionGrant[]        @relation("AdminPermissionGrants")
  adminPermissionsGrantedBy AdminPermissionGrant[]        @relation("AdminPermissionGrantedBy")
  featuredItemsCreated      FeaturedItem[]                @relation("FeaturedByAdmin")
  featuredItemsRemoved      FeaturedItem[]                @relation("RemovedByAdmin")
  adminSlaConfigsCreated    AdminSlaConfig[]              @relation("AdminSlaConfigCreatedBy")
  adminNotificationsSent    AdminNotificationLog[]        @relation("AdminNotificationsSent")
  disputesReported          Dispute[]                     @relation("DisputeReporter")
  disputesAssigned          Dispute[]                     @relation("DisputeAssignedTo")
  disputesResolved          Dispute[]                     @relation("DisputeResolvedBy")
  passwordResetTokens       PasswordResetToken[]          @relation("PasswordResetTokens")
  reactivationRequests      AccountReactivationRequest[]  @relation("UserReactivationRequests")
  reviewedReactivationRequests AccountReactivationRequest[] @relation("AdminReviewedReactivationRequests")
}

model FileUpload {
  id           String   @id @map("_id") @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation("UserFiles", fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  fileName     String
  s3Key        String   @unique
  s3Url        String
  fileType     FileType
  mimeType     String
  size         Int
  processingStatus ImageProcessingStatus @default(PENDING)
  processingError  String?
  width            Int?
  height           Int?
  hasAlpha         Boolean               @default(false)
  isAnimated       Boolean               @default(false)
  orientation      Int?
  colorSpace       String?
  sha256           String?
  assetVersion     Int                   @default(1)
  isPublic         Boolean               @default(false)
  originalDeletedAt DateTime?
  lastProcessedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations for profile images
  profileUsers User[] @relation("UserProfileImage")

  // Relations for posts
  posts      Post[] @relation("PostImages")
  postVideos Post[] @relation("PostVideos")

  // Relation to collection media
  collectionMedias CollectionMedia[] @relation("FileUpload_to_CollectionMedia")
  bannerUsers      User[]            @relation("UserBannerImage")
  variants         FileVariant[]

  @@index([processingStatus, updatedAt])
}

model FileVariant {
  id           String        @id @map("_id") @db.Uuid
  fileUploadId String        @db.Uuid
  file         FileUpload    @relation(fields: [fileUploadId], references: [id], onDelete: Cascade)
  variantKind  ImageVariantKind
  format       ImageVariantFormat
  width        Int
  height       Int
  sizeBytes    Int
  quality      Int
  s3Key        String
  s3Url        String
  assetVersion Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([fileUploadId, variantKind])
  @@unique([fileUploadId, variantKind, format, assetVersion])
}

model Post {
  id            String       @id @map("_id") @db.Uuid
  userId        String       @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String?
  imageIds      String[]     @db.Uuid
  images        FileUpload[] @relation("PostImages")
  videoId       String?      @db.Uuid
  video         FileUpload?  @relation("PostVideos", fields: [videoId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  comments      Comment[]
  threads       Thread[]
  threadsCount  Int          @default(0) @map("likesCount")
  commentsCount Int          @default(0)
}

model Comment {
  id        String   @id @map("_id") @db.Uuid
  postId    String   @db.Uuid
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id         String    @id @map("_id") @db.Uuid
  tokenHash  String    @unique
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([expiresAt])
}

enum Role {
  SuperAdmin
  Admin
  User
}

enum UserType {
  BRAND
  REGULAR
}

enum ProfileVisibility {
  UNLOCKED
  LOCKED
}

enum SizeFitVisibility {
  PUBLIC
  PRIVATE
}

enum SizeFitSharePolicy {
  OWNER_ONLY
  REQUIRE_PERMISSION
  ALLOW_ANYONE
}

enum SizeFitShareStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum SizingMode {
  NONE
  RTW
  CUSTOM
  RTW_PLUS_CUSTOM
}

enum RtwSizeType {
  PREDEFINED
  FREEFORM
  MIXED
}

enum FitPreference {
  SLIM
  REGULAR
  LOOSE
  OVERSIZED
}

enum AgeGroup {
  ADULT
  CHILD
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum MeasurementPointCategory {
  UPPER_BODY
  ARMS
  LOWER_BODY
  LENGTH
  GENERAL
  ACCESSORIES
}

enum MeasurementPointSource {
  SYSTEM
  BRAND_FREEFORM
}

enum FreeformPointStatus {
  BRAND_ONLY
  APPROVED_GLOBAL
  REJECTED
}

enum BrandSizeChartStatus {
  DRAFT
  PENDING
  PUBLISHED
  SENT_BACK
}

enum DisputeStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DisputeResolution {
  ACCEPT_REFUND
  PARTIAL_REFUND
  REJECT_CLAIM
  ESCALATED
}

enum FileType {
  PROFILE_IMAGE
  BANNER_IMAGE
  POST_IMAGE
  POST_VIDEO
  DOCUMENT
  BRAND_VERIFICATION
}

enum ImageProcessingStatus {
  PENDING
  READY
  FAILED
}

enum ImageVariantKind {
  AVATAR
  BANNER
  THUMB
  CARD
  DETAIL
  ZOOM
}

enum ImageVariantFormat {
  AVIF
  WEBP
  JPEG
  PNG
}

enum PresignStatus {
  PENDING
  READY
  USED
  EXPIRED
}

enum TagEntityType {
  COLLECTION
  PRODUCT
  BRAND
  USER_BRAND
}

model Thread {
  id            String   @id @map("_id") @db.Uuid
  postId        String   @db.Uuid
  userId        String   @db.Uuid
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId String?  @unique
  createdAt     DateTime @default(now())

  @@unique([postId, userId]) // Prevent duplicate threads
  @@map("Like")
}

enum ReactionType {
  THREAD
  DISLIKE
}

enum NotificationType {
  SIGNUP
  LOGIN
  COLLECTION_UPLOAD
  PRODUCT_UPLOAD
  COLLECTION_DELETED
  THREAD
  COMMENT
  PATCH
  FOLLOW
  TAG_MENTION
  LOGOUT
  LOGOUT_ALL
  // Private collection access workflow
  PRIVATE_ACCESS_REQUESTED
  PRIVATE_ACCESS_APPROVED
  PRIVATE_ACCESS_REJECTED
  PRIVATE_ACCESS_REVOKED
  
  // Brand Patching
  BRAND_PATCH_REQUEST
  BRAND_PATCH_ACCEPTED
  BRAND_PATCH_REJECTED

  // Orders
  ORDER_PLACED
  ORDER_STATUS_UPDATED

  // Contributions
  CONTRIBUTION_REQUEST
  CONTRIBUTION_ACCEPTED
  CONTRIBUTION_REJECTED

  // Size fit reminders and sharing
  SIZE_FIT_UPDATE_REMINDER
  SIZE_FIT_SHARED
  SIZE_FIT_SHARE_REQUEST
  SIZE_FIT_SHARE_APPROVED
  SIZE_FIT_SHARE_REJECTED
  SIZE_FIT_RESHARED

  // Wishlist availability
  WISHLIST_PRODUCT_UNAVAILABLE
  WISHLIST_PRODUCT_AVAILABLE

  // Admin actions
  ADMIN_ACTION

  // Featured system
  ITEM_FEATURED
  FEATURED_AUTO_REMOVED

  // Brand verification
  VERIFICATION_SUBMITTED
  VERIFICATION_IN_REVIEW
  VERIFICATION_INFO_REQUESTED
  VERIFICATION_INFO_RESUBMITTED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  VERIFICATION_CANCELLED
  VERIFICATION_CANCELLED_ADMIN
  VERIFICATION_COOLDOWN_EXPIRED
  VERIFICATION_NUDGE
  VERIFICATION_SLA_WARNING
  VERIFICATION_SLA_BREACH
  VERIFICATION_REVIEW_DELAYED
}

// ====== Comment V2 (unified for posts, collections, and collection media) ======

enum CommentTarget {
  POST
  COLLECTION
  COLLECTION_MEDIA
}

model CommentV2 {
  id               String          @id @map("_id") @db.Uuid
  targetType       CommentTarget
  targetId         String          @db.Uuid
  userId           String          @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId         String?         @db.Uuid
  parent           CommentV2?      @relation("CommentV2Children", fields: [parentId], references: [id])
  children         CommentV2[]     @relation("CommentV2Children")
  depth            Int             @default(0)
  contentRaw       String
  contentSanitized String
  threadsCount     Int             @default(0) @map("likeCount")
  replyCount       Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?
  version          Int             @default(1)
  threads          CommentV2Thread[]

  @@index([targetType, targetId, createdAt])
  @@index([parentId, createdAt])
}

model CommentV2Thread {
  id        String    @id @map("_id") @db.Uuid
  commentId String    @db.Uuid
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  comment   CommentV2 @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("CommentV2Like")
}

model Follow {
  id          String   @id @map("_id") @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  follower    User     @relation("followerFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followingFollows", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Collection {
  id                           String                          @id @map("_id") @db.Uuid
  ownerId                      String                          @db.Uuid
  owner                        User                            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  domain                       CollectionDomain                @default(DESIGN)
  title                        String?
  description                  String?
  searchVector                 Unsupported("tsvector")?       @map("search_vector")
  status                       CollectionStatus                @default(DRAFT)
  archivedFromStatus           CollectionStatus?
  visibility                   CollectionVisibility            @default(PUBLIC)
  type                         CollectionType                  @default(EVERYBODY)
  categoryId                   String?                         @db.Uuid
  category                     CollectionCategory?             @relation(fields: [categoryId], references: [id])
  categoryTypeId               String?                         @db.Uuid
  categoryType                 CollectionCategoryType?         @relation(fields: [categoryTypeId], references: [id], onDelete: SetNull)
  coverMediaId                 String?                         @db.Uuid
  coverMedia                   CollectionMedia?                @relation("CollectionCoverMedia", fields: [coverMediaId], references: [id])
  deletedAt                    DateTime?
  deleteExpiresAt              DateTime?
  lastActivityAt               DateTime?
  draftVersion                 Int                             @default(0)
  // PHASE 1: Pending category support for draft collections
  pendingCategorySuggestionId  String?                         @db.Uuid
  pendingCategorySuggestion    CollectionCategorySuggestion?   @relation(fields: [pendingCategorySuggestionId], references: [id], onDelete: SetNull)
  draftReason                  String?                         // Enum-like: "AWAITING_CATEGORY_APPROVAL", "USER_SAVED", "CATEGORY_REJECTED", "UPLOAD_INCOMPLETE"
  pendingCategoryName          String?                         // Human-readable name for UI display
  originalSuggestionId         String?                         @db.Uuid // Audit trail - maintains reference even after approval/rejection
  minPrice                     Float?
  maxPrice                     Float?
  isAvailableInStore           Boolean                         @default(false)
  tags                         String[]                        @default([])
  // Optional sale/discount fields
  saleMinPrice                 Float?
  saleMaxPrice                 Float?
  saleStartAt                  DateTime?
  saleEndAt                    DateTime?
  sizingMode                   SizingMode                      @default(NONE)
  rtwSizes                     String[]                        @default([])
  rtwSizeSystem                String?
  rtwSizeType                  RtwSizeType?
  customGender                 Gender?
  customMeasurementKeys        String[]                        @default([])
  customFreeformPointIds       String[]                        @default([])
  fitPreference                FitPreference?
  targetAgeGroup               AgeGroup                        @default(ADULT)
  createdAt                    DateTime                        @default(now())
  updatedAt                    DateTime                        @updatedAt
  metadataEditedAt             DateTime?                       // Last title/description edit timestamp (30-day cooldown)
  threadsCount                 Int                             @default(0) @map("likesCount")
  dislikesCount                Int                             @default(0)
  commentsCount                Int                             @default(0)
  collectionCollabsCount       Int                             @default(0) @map("patchesCount")
  viewsCount                   Int                             @default(0)
  medias                       CollectionMedia[]               @relation("Collection_to_Media")
  reactions                    CollectionReaction[]
  comments                     CollectionComment[]
  collectionCollabs            CollectionCollab[]              @relation("Collection_to_Collab")
  views                        View[]                          @relation("Collection_to_View")
  // Access approvals for private collections
  accesses                     CollectionAccess[]
  
  // Contributions
  contributionRequests         ContributionRequest[]           @relation("CollectionContributionRequests")
  
  // E-commerce products (multi-collection membership)
  // Featured system
  isFeaturedBlocked            Boolean                         @default(false)

  products                     CollectionProduct[]
  draftSessions                CollectionDraftSession[]
  bulkUploadJobs               CollectionBulkUploadJob[]

  @@index([status, createdAt])
  @@index([status, collectionCollabsCount])
  @@index([status, visibility, createdAt])
  @@index([status, pendingCategorySuggestionId]) // PHASE 1: Fast lookup of drafts waiting for category approval
  @@index([ownerId, status, createdAt]) // PHASE 1: User's draft management
  @@index([ownerId, domain, status, createdAt])
  @@index([categoryTypeId])
  @@index([deletedAt])
  @@index([deleteExpiresAt])
  @@index([lastActivityAt])
}

model StoreCollection {
  id                 String                  @id @map("_id") @db.Uuid
  ownerId            String                  @db.Uuid
  owner              User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title              String?
  description        String?
  searchVector       Unsupported("tsvector")? @map("search_vector")
  status             CollectionStatus        @default(DRAFT)
  archivedFromStatus CollectionStatus?
  visibility         CollectionVisibility    @default(PUBLIC)
  type               CollectionType          @default(EVERYBODY)
  categoryId         String?                 @db.Uuid
  category           CollectionCategory?     @relation(fields: [categoryId], references: [id])
  categoryTypeId     String?                 @db.Uuid
  categoryType       CollectionCategoryType? @relation(fields: [categoryTypeId], references: [id], onDelete: SetNull)
  deletedAt          DateTime?
  deleteExpiresAt    DateTime?
  lastActivityAt     DateTime?
  draftVersion       Int                     @default(0)
  minPrice           Float?
  maxPrice           Float?
  isAvailableInStore Boolean                 @default(true)
  isSystemGenerated  Boolean                 @default(false)
  tags               String[]                @default([])
  saleMinPrice       Float?
  saleMaxPrice       Float?
  saleStartAt        DateTime?
  saleEndAt          DateTime?
  derivedSizeRange   String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  metadataEditedAt   DateTime?
  threadsCount       Int                     @default(0) @map("likesCount")
  dislikesCount      Int                     @default(0)
  commentsCount      Int                     @default(0)
  collectionCollabsCount Int                 @default(0) @map("patchesCount")
  viewsCount         Int                     @default(0)
  products           StoreCollectionProduct[]
  primaryProducts    Product[]               @relation("PrimaryStoreCollection")

  @@index([status, createdAt])
  @@index([status, visibility, createdAt])
  @@index([ownerId, status, createdAt])
  @@index([ownerId, visibility, status, createdAt])
  @@index([categoryTypeId])
  @@index([deletedAt])
  @@index([deleteExpiresAt])
  @@index([lastActivityAt])
}

enum CollectionDomain {
  DESIGN
  STORE
}

enum BulkUploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum BulkUploadRowStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  SKIPPED
}

model CollectionDraftSession {
  id              String     @id @map("_id") @db.Uuid
  collectionId    String     @db.Uuid
  ownerId         String     @db.Uuid
  sessionToken    String     @unique
  deviceName      String?
  deviceType      String?
  startedAt       DateTime   @default(now())
  lastHeartbeatAt DateTime   @default(now())
  expiresAt       DateTime
  isActive        Boolean    @default(true)

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  owner           User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([collectionId, isActive])
  @@index([ownerId])
  @@index([expiresAt])
}

model CollectionBulkUploadJob {
  id            String           @id @map("_id") @db.Uuid
  collectionId  String           @db.Uuid
  ownerId       String           @db.Uuid
  status        BulkUploadStatus @default(PENDING)
  mode          String?
  totalRows     Int              @default(0)
  processedRows Int              @default(0)
  successRows   Int              @default(0)
  failedRows    Int              @default(0)
  errorSummary  Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  completedAt   DateTime?

  collection    Collection       @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rows          CollectionBulkUploadRow[]

  @@index([collectionId, createdAt])
  @@index([ownerId, createdAt])
  @@index([status, createdAt])
}

model CollectionBulkUploadRow {
  id              String              @id @map("_id") @db.Uuid
  jobId           String              @db.Uuid
  rowIndex        Int
  rowId           String?
  status          BulkUploadRowStatus @default(PENDING)
  errorMessage    String?
  payload         Json?
  createdProductId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  job             CollectionBulkUploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, rowIndex])
  @@unique([jobId, rowId])
  @@index([jobId, status])
  @@index([rowId])
}

model CollectionProduct {
  id           String   @id @map("_id") @db.Uuid
  collectionId String   @db.Uuid
  productId    String   @db.Uuid
  orderIndex   Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([productId])
  @@index([collectionId, orderIndex])
}

model StoreCollectionProduct {
  id           String   @id @map("_id") @db.Uuid
  collectionId String   @db.Uuid
  productId    String   @db.Uuid
  orderIndex   Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  collection   StoreCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([productId])
  @@index([collectionId, orderIndex])
}

enum CollectionStatus {
  DRAFT // Created but files not uploaded
  PUBLISHED // Fully published and visible
  ARCHIVED // Hidden from public view
}

enum CollectionVisibility {
  PUBLIC
  PRIVATE
}

enum CollectionType {
  MALE
  FEMALE
  EVERYBODY
}

model CollectionCategory {
  id                      String                          @id @map("_id") @db.Uuid
  slug                    String                          @unique
  name                    String
  description             String?
  isActive                Boolean                         @default(true)
  order                   Int                             @default(0)
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  collections             Collection[]
  storeCollections        StoreCollection[]
  products                Product[]
  types                   CollectionCategoryType[]
  // PHASE 1: Approved suggestions that created this category
  approvedSuggestions     CollectionCategorySuggestion[]

  @@index([isActive, order])
}

model CollectionCategoryType {
  id          String               @id @map("_id") @db.Uuid
  categoryId  String               @db.Uuid
