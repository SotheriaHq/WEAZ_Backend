generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                        @id @map("_id") @db.Uuid
  username                 String                        @unique
  role                     Role                          @default(User)
  type                     UserType                      @default(REGULAR)
  email                    String                        @unique
  password                 String?
  passwordCredentialStatus PasswordCredentialStatus      @default(ENABLED)
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  refreshTokens            RefreshToken[]
  studioHandoffCodes       StudioHandoffCode[]
  fileUploads              FileUpload[]                  @relation("UserFiles")
  posts                    Post[]
  comments                 Comment[]
  threads                  Thread[]
  commentsV2               CommentV2[]
  commentV2Threads         CommentV2Thread[]
  isEmailVerified          Boolean                       @default(false)
  emailVerificationCode    String?                       @unique
  pendingEmail             String?                       @unique
  pendingEmailTokenHash    String?                       @unique
  pendingEmailExpiresAt    DateTime?
  isActive                 String                        @default("Active")
  notificationSettings     Json? // Stores user preferences { security: { login: true }, engagement: { threads: true } }
  themePreference          String                        @default("system") // Saved appearance preference: light, dark, or system. Resolved theme stays client-only.
  emailPreference          UserEmailPreference?
  emailScenarioPreferences UserEmailScenarioPreference[]
  trustedDevices           TrustedDevice[]
  emailPreferenceAudits    UserEmailPreferenceAudit[]    @relation("EmailPreferenceAuditSubject")
  emailPreferenceChanges   UserEmailPreferenceAudit[]    @relation("EmailPreferenceAuditActor")
  emailOutboxEvents        EmailOutbox[]                 @relation("EmailOutboxRecipient")
  authIdentities           AuthIdentity[]
  emailLoginCodes          EmailLoginCode[]
  passwordSetupTokens      PasswordSetupToken[]
  legalAcceptances         LegalAcceptance[]
  profilePhotoViewsOwned   ProfilePhotoView[]            @relation("ProfilePhotoViewOwner")
  profilePhotoViewsMade    ProfilePhotoView[]            @relation("ProfilePhotoViewViewer")

  // Admin Console fields
  status               UserStatus @default(ACTIVE)
  adminSuspendedAt     DateTime?
  adminSuspendedReason String?
  deactivatedAt        DateTime?
  deactivatedReason    String?
  mustResetPassword    Boolean    @default(false)
  authVersion          Int        @default(0)

  // Relations for new social models
  followerFollows  Follow[] @relation("followerFollows")
  followingFollows Follow[] @relation("followingFollows")

  // Brand Patching (Mutual)
  sentPatchRequests     BrandPatch[] @relation("SentPatchRequests")
  receivedPatchRequests BrandPatch[] @relation("ReceivedPatchRequests")
  createdTags           Tag[]        @relation("TagCreator")

  // Contributions
  contributionRequests ContributionRequest[] @relation("UserContributionRequests")

  collections              Collection[]
  designs                  Design[]                       @relation("UserDesigns")
  storeCollections         StoreCollection[]
  collectionReactions      CollectionReaction[]
  collectionComments       CollectionComment[]
  commentReactions         CommentReaction[]
  collectionCollabsMade    CollectionCollab[]             @relation("UserCollectionCollabs")
  patchConnectionsMade     PatchConnection[]              @relation("PatchRequester")
  patchConnectionsReceived PatchConnection[]              @relation("PatchTarget")
  savedItems               SavedItem[]                    @relation("UserSavedItems")
  views                    View[]
  notificationsReceived    Notification[]                 @relation("UserNotificationsReceived")
  notificationsActed       Notification[]                 @relation("UserNotificationsActed")
  pushDeviceTokens         PushDeviceToken[]
  presignedUploads         PresignedUpload[]
  CollectionMediaReaction  CollectionMediaReaction[]
  // Access to private collections (viewer side)
  collectionAccesses       CollectionAccess[]
  // PHASE 1: Category suggestions
  proposedSuggestions      CollectionCategorySuggestion[] @relation("ProposedCategorySuggestions")
  decidedSuggestions       CollectionCategorySuggestion[] @relation("DecidedCategorySuggestions")
  // Brand Relation
  brand                    Brand?                         @relation("BrandOwner")
  brandMemberships         BrandMember[]

  // Orders as buyer
  ordersAsBuyer                       Order[]                              @relation("OrderBuyer")
  customOrdersAsBuyer                 CustomOrder[]                        @relation("CustomOrderBuyer")
  customOrderCheckoutSessions         CustomOrderCheckoutSession[]
  checkoutSessions                    CheckoutSession[]
  userProfile                         UserProfile?
  sizeFitProfile                      UserSizeFitProfile?
  sizeFitSharesOwned                  UserSizeFitShare[]                   @relation("SizeFitOwnerShares")
  sizeFitSharesReceived               UserSizeFitShare[]                   @relation("SizeFitViewerShares")
  sizeFitShareRequestsMade            UserSizeFitShare[]                   @relation("SizeFitRequestedBy")
  sizeFitRevisions                    UserSizeFitRevision[]                @relation("SizeFitRevisionAuthor")
  sizeRecommendationSnapshots         UserSizeRecommendationSnapshot[]
  customOrderMeasurementContributions CustomOrderMeasurementContribution[]

  // Idempotency keys (safe retries for POST requests)
  idempotencyKeys           IdempotencyKey[]
  savedPaymentMethods       SavedPaymentMethod[]
  cardValidationSessions    CardValidationSession[]
  messageThreadParticipants MessageThreadParticipant[]
  messagesAuthored          Message[]                  @relation("MessageSender")
  messageDeliveryReceipts   MessageDeliveryReceipt[]   @relation("MessageDeliveryReceipts")
  collectionDraftSessions   CollectionDraftSession[]
  designDraftSessions       DesignDraftSession[]       @relation("UserDesignDraftSessions")
  collectionBulkUploadJobs  CollectionBulkUploadJob[]

  // Admin Console relations
  adminPermissionGrants        AdminPermissionGrant[]       @relation("AdminPermissionGrants")
  adminPermissionsGrantedBy    AdminPermissionGrant[]       @relation("AdminPermissionGrantedBy")
  featuredItemsCreated         FeaturedItem[]               @relation("FeaturedByAdmin")
  featuredItemsRemoved         FeaturedItem[]               @relation("RemovedByAdmin")
  adminSlaConfigsCreated       AdminSlaConfig[]             @relation("AdminSlaConfigCreatedBy")
  adminNotificationsSent       AdminNotificationLog[]       @relation("AdminNotificationsSent")
  disputesReported             Dispute[]                    @relation("DisputeReporter")
  disputesAssigned             Dispute[]                    @relation("DisputeAssignedTo")
  disputesResolved             Dispute[]                    @relation("DisputeResolvedBy")
  payoutsApproved              Payout[]                     @relation("PayoutApprovedBy")
  payoutsAssigned              Payout[]                     @relation("PayoutAssignedTo")
  escrowHoldsAsBuyer           EscrowHold[]                 @relation("EscrowHoldBuyer")
  escrowHoldsFrozen            EscrowHold[]                 @relation("EscrowHoldFrozenBy")
  exchangeRateSnapshotsCreated ExchangeRateSnapshot[]       @relation("ExchangeRateSnapshotCreatedBy")
  passwordResetTokens          PasswordResetToken[]         @relation("PasswordResetTokens")
  reactivationRequests         AccountReactivationRequest[] @relation("UserReactivationRequests")
  reviewedReactivationRequests AccountReactivationRequest[] @relation("AdminReviewedReactivationRequests")

  // Product Reviews
  productReviews            ProductReview[]            @relation("UserProductReviews")
  reviewHelpfulVotes        ProductReviewHelpfulVote[] @relation("UserReviewHelpfulVotes")
  productReviewReports      ProductReviewReport[]      @relation("UserProductReviewReports")
  lifecycleReviews          Review[]                   @relation("ReviewReviewer")
  lifecycleReviewsDeleted   Review[]                   @relation("ReviewDeletedBy")
  reviewPrompts             ReviewPrompt[]             @relation("ReviewPromptBuyer")
  systemConfigUpdates       SystemConfig[]             @relation("SystemConfigUpdater")
  ledgerTransactionsCreated LedgerTransaction[]        @relation("LedgerTransactionCreatedBy")
  adminEmailChangeRequests  AdminEmailChangeRequest[]  @relation("AdminEmailChangeRequests")
  adminEmailChangeReviewed  AdminEmailChangeRequest[]  @relation("AdminEmailChangeReviewedBy")
}

model FileUpload {
  id                String                @id @map("_id") @db.Uuid
  userId            String                @db.Uuid
  user              User                  @relation("UserFiles", fields: [userId], references: [id], onDelete: Cascade)
  originalName      String
  fileName          String
  s3Key             String                @unique
  s3Url             String
  fileType          FileType
  mimeType          String
  size              Int
  processingStatus  ImageProcessingStatus @default(PENDING)
  processingError   String?
  width             Int?
  height            Int?
  hasAlpha          Boolean               @default(false)
  isAnimated        Boolean               @default(false)
  orientation       Int?
  colorSpace        String?
  sha256            String?
  assetVersion      Int                   @default(1)
  isPublic          Boolean               @default(false)
  originalDeletedAt DateTime?
  lastProcessedAt   DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  // Relations for profile images
  userProfileImages UserProfile[] @relation("UserProfileProfileImage")

  // Relations for posts
  posts      Post[] @relation("PostImages")
  postVideos Post[] @relation("PostVideos")

  // Relation to collection media
  collectionMedias   CollectionMedia[]   @relation("FileUpload_to_CollectionMedia")
  designMedias       DesignMedia[]       @relation("FileUpload_to_DesignMedia")
  productMedias      ProductMedia[]      @relation("FileUpload_to_ProductMedia")
  userProfileBanners UserProfile[]       @relation("UserProfileBannerImage")
  variants           FileVariant[]
  messageAttachments MessageAttachment[]

  @@index([processingStatus, updatedAt])
}

model UserProfile {
  id                    String            @id @default(uuid()) @map("_id") @db.Uuid
  userId                String            @unique @db.Uuid
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName             String
  lastName              String
  phoneNumber           String?
  address               String?
  profileImage          String?
  profileImageId        String?           @db.Uuid
  profileImageFile      FileUpload?       @relation("UserProfileProfileImage", fields: [profileImageId], references: [id])
  profilePhotoUpdatedAt DateTime?
  bannerImage           String?
  bannerImageId         String?           @db.Uuid
  bannerImageFile       FileUpload?       @relation("UserProfileBannerImage", fields: [bannerImageId], references: [id])
  profileVisibility     ProfileVisibility @default(UNLOCKED)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([profileVisibility])
}

model ProfilePhotoView {
  id             String   @id @default(uuid()) @map("_id") @db.Uuid
  ownerId        String   @db.Uuid
  viewerId       String   @db.Uuid
  photoUpdatedAt DateTime
  viewedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner  User @relation("ProfilePhotoViewOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  viewer User @relation("ProfilePhotoViewViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, viewerId, photoUpdatedAt])
  @@index([ownerId, photoUpdatedAt])
  @@index([viewerId, viewedAt])
}

model FileVariant {
  id           String             @id @map("_id") @db.Uuid
  fileUploadId String             @db.Uuid
  file         FileUpload         @relation(fields: [fileUploadId], references: [id], onDelete: Cascade)
  variantKind  ImageVariantKind
  format       ImageVariantFormat
  width        Int
  height       Int
  sizeBytes    Int
  quality      Int
  s3Key        String
  s3Url        String
  assetVersion Int                @default(1)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([fileUploadId, variantKind, format, assetVersion])
  @@index([fileUploadId, variantKind])
}

model Post {
  id            String       @id @map("_id") @db.Uuid
  userId        String       @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String?
  imageIds      String[]     @db.Uuid
  images        FileUpload[] @relation("PostImages")
  videoId       String?      @db.Uuid
  video         FileUpload?  @relation("PostVideos", fields: [videoId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  comments      Comment[]
  threads       Thread[]
  threadsCount  Int          @default(0) @map("likesCount")
  commentsCount Int          @default(0)
}

model Comment {
  id        String   @id @map("_id") @db.Uuid
  postId    String   @db.Uuid
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id            String    @id @map("_id") @db.Uuid
  tokenHash     String    @unique
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent     String?
  ipAddress     String?
  locationLabel String?
  lastUsedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model StudioHandoffCode {
  id           String    @id @map("_id") @db.Uuid
  codeHash     String    @unique
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  intendedPath String
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        AuthProvider
  providerSubject String
  email           String?
  emailVerified   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([email])
}

model EmailLoginCode {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   LoginCodePurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int              @default(0)
  createdAt DateTime         @default(now())

  @@index([userId, purpose, expiresAt])
  @@index([codeHash])
}

model PasswordSetupToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model LegalAcceptance {
  id          String                @id @default(uuid()) @map("_id") @db.Uuid
  userId      String                @db.Uuid
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentKey LegalDocumentKey
  version     String
  source      LegalAcceptanceSource
  surface     String
  accountType UserType?
  ipAddress   String?
  userAgent   String?
  locale      String?
  appVersion  String?
  metadata    Json?
  acceptedAt  DateTime              @default(now())
  createdAt   DateTime              @default(now())

  @@unique([userId, documentKey, version, source])
  @@index([userId, documentKey, acceptedAt])
  @@index([documentKey, version])
}

