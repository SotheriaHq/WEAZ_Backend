  amount                         Decimal      @db.Decimal(10, 2)
  currency                       String       @default("NGN")
  status                         PayoutStatus @default(PENDING_APPROVAL)
  provider                       String       @default("PAYSTACK")
  reference                      String?
  gatewayReference               String?
  providerRecipientCode          String?
  providerRecipientId            String?
  providerTransferCode           String?      @unique
  providerTransferId             String?
  providerTransferReference      String?      @unique
  providerTransferStatus         String?
  providerTransferFailureCode    String?
  providerTransferFailureMessage String?
