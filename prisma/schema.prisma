// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @map("_id") @db.Uuid
  username              String          @unique
  role                  Role            @default(User)
  type                  UserType        @default(REGULAR)
  firstName             String
  lastName              String
  email                 String          @unique
  password              String
  phoneNumber           String?
  address               String?
  brandFullName         String?
  cacNumber             String?         @unique
  tin                   String?         @unique
  ceoNin                String?         @unique
  ceoFirstName          String?
  ceoLastName           String?
  companyLocation       String?
  brandDescription      String?
  brandCountry          String?
  brandState            String?
  brandCity             String?
  brandTags             String[]        @default([])
  brandBusinessType     String?
  socialInstagram       String?
  socialFacebook        String?
  socialTwitter         String?
  socialWebsite         String?
  profileImage          String?
  profileImageId        String?         @db.Uuid
  profileImageFile      FileUpload?     @relation("UserProfileImage", fields: [profileImageId], references: [id])
  bannerImage           String?
  bannerImageId         String?         @db.Uuid
  bannerImageFile       FileUpload?     @relation("UserBannerImage", fields: [bannerImageId], references: [id])
  industriNumber        String?         @unique
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  refreshTokens         RefreshToken[]
  fileUploads           FileUpload[]    @relation("UserFiles")
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]
  commentsV2            CommentV2[]
  commentV2Likes        CommentV2Like[]
  isEmailVerified       Boolean         @default(false)
  emailVerificationCode String?         @unique
  isActive              String          @default("Active")
  notificationSettings  Json?           // Stores user preferences { security: { login: true }, engagement: { likes: true } }

  // Relations for new social models
  followerFollows         Follow[]                        @relation("followerFollows")
  followingFollows        Follow[]                        @relation("followingFollows")
  
  // Brand Patching (Mutual)
  sentPatchRequests       BrandPatch[]                    @relation("SentPatchRequests")
  receivedPatchRequests   BrandPatch[]                    @relation("ReceivedPatchRequests")

  // Contributions
  contributionRequests    ContributionRequest[]           @relation("UserContributionRequests")

  collections             Collection[]
  collectionReactions     CollectionReaction[]
  collectionComments      CollectionComment[]
  commentReactions        CommentReaction[]
  patchesMade             Patch[]                         @relation("UserPatches")
  views                   View[]
  notificationsReceived   Notification[]                  @relation("UserNotificationsReceived")
  notificationsActed      Notification[]                  @relation("UserNotificationsActed")
  presignedUploads        PresignedUpload[]
  CollectionMediaReaction CollectionMediaReaction[]
  // Access to private collections (viewer side)
  collectionAccesses      CollectionAccess[]
  // PHASE 1: Category suggestions
  proposedSuggestions     CollectionCategorySuggestion[]  @relation("ProposedCategorySuggestions")
  decidedSuggestions      CollectionCategorySuggestion[]  @relation("DecidedCategorySuggestions")
  // Brand Relation
  brand                   Brand?                          @relation("BrandOwner")
}

model FileUpload {
  id           String   @id @map("_id") @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation("UserFiles", fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  fileName     String
  s3Key        String   @unique
  s3Url        String
  fileType     FileType
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations for profile images
  profileUsers User[] @relation("UserProfileImage")

  // Relations for posts
  posts      Post[] @relation("PostImages")
  postVideos Post[] @relation("PostVideos")

  // Relation to collection media
  collectionMedias CollectionMedia[] @relation("FileUpload_to_CollectionMedia")
  bannerUsers      User[]            @relation("UserBannerImage")
}

model Post {
  id            String       @id @map("_id") @db.Uuid
  userId        String       @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String?
  imageIds      String[]     @db.Uuid
  images        FileUpload[] @relation("PostImages")
  videoId       String?      @db.Uuid
  video         FileUpload?  @relation("PostVideos", fields: [videoId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  comments      Comment[]
  likes         Like[]
  likesCount    Int          @default(0)
  commentsCount Int          @default(0)
}

model Comment {
  id        String   @id @map("_id") @db.Uuid
  postId    String   @db.Uuid
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id         String    @id @map("_id") @db.Uuid
  tokenHash  String    @unique
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt])
}

enum Role {
  SuperAdmin
  Admin
  User
}

enum UserType {
  BRAND
  REGULAR
}

enum FileType {
  PROFILE_IMAGE
  BANNER_IMAGE
  POST_IMAGE
  POST_VIDEO
  DOCUMENT
}

enum PresignStatus {
  PENDING
  READY
  USED
  EXPIRED
}

model Like {
  id            String   @id @map("_id") @db.Uuid
  postId        String   @db.Uuid
  userId        String   @db.Uuid
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId String?  @unique
  createdAt     DateTime @default(now())

  @@unique([postId, userId]) // Prevent duplicate likes
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  SIGNUP
  LOGIN
  COLLECTION_UPLOAD
  COLLECTION_DELETED
  LIKE
  COMMENT
  PATCH
  FOLLOW
  LOGOUT
  LOGOUT_ALL
  // Private collection access workflow
  PRIVATE_ACCESS_REQUESTED
  PRIVATE_ACCESS_APPROVED
  PRIVATE_ACCESS_REJECTED
  PRIVATE_ACCESS_REVOKED
  
  // Brand Patching
  BRAND_PATCH_REQUEST
  BRAND_PATCH_ACCEPTED
  BRAND_PATCH_REJECTED

  // Contributions
  CONTRIBUTION_REQUEST
  CONTRIBUTION_ACCEPTED
  CONTRIBUTION_REJECTED
}

// ====== Comment V2 (unified for posts, collections, and collection media) ======

enum CommentTarget {
  POST
  COLLECTION
  COLLECTION_MEDIA
}

model CommentV2 {
  id               String          @id @map("_id") @db.Uuid
  targetType       CommentTarget
  targetId         String          @db.Uuid
  userId           String          @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId         String?         @db.Uuid
  parent           CommentV2?      @relation("CommentV2Children", fields: [parentId], references: [id])
  children         CommentV2[]     @relation("CommentV2Children")
  depth            Int             @default(0)
  contentRaw       String
  contentSanitized String
  likeCount        Int             @default(0)
  replyCount       Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?
  version          Int             @default(1)
  likes            CommentV2Like[]

  @@index([targetType, targetId, createdAt])
  @@index([parentId, createdAt])
}

model CommentV2Like {
  id        String    @id @map("_id") @db.Uuid
  commentId String    @db.Uuid
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  comment   CommentV2 @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
}

model Follow {
  id          String   @id @map("_id") @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  follower    User     @relation("followerFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followingFollows", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Collection {
  id                           String                          @id @map("_id") @db.Uuid
  ownerId                      String                          @db.Uuid
  owner                        User                            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title                        String?
  description                  String?
  status                       CollectionStatus                @default(DRAFT)
  visibility                   CollectionVisibility            @default(PUBLIC)
  type                         CollectionType                  @default(EVERYBODY)
  categoryId                   String?                         @db.Uuid
  category                     CollectionCategory?             @relation(fields: [categoryId], references: [id])
  coverMediaId                 String?                         @db.Uuid
  coverMedia                   CollectionMedia?                @relation("CollectionCoverMedia", fields: [coverMediaId], references: [id])
  // PHASE 1: Pending category support for draft collections
  pendingCategorySuggestionId  String?                         @db.Uuid
  pendingCategorySuggestion    CollectionCategorySuggestion?   @relation(fields: [pendingCategorySuggestionId], references: [id], onDelete: SetNull)
  draftReason                  String?                         // Enum-like: "AWAITING_CATEGORY_APPROVAL", "USER_SAVED", "CATEGORY_REJECTED", "UPLOAD_INCOMPLETE"
  pendingCategoryName          String?                         // Human-readable name for UI display
  originalSuggestionId         String?                         @db.Uuid // Audit trail - maintains reference even after approval/rejection
  minPrice                     Float?
  maxPrice                     Float?
  isAvailableInStore           Boolean                         @default(false)
  tags                         String[]                        @default([])
  // Optional sale/discount fields
  saleMinPrice                 Float?
  saleMaxPrice                 Float?
  saleStartAt                  DateTime?
  saleEndAt                    DateTime?
  createdAt                    DateTime                        @default(now())
  updatedAt                    DateTime                        @updatedAt
  likesCount                   Int                             @default(0)
  dislikesCount                Int                             @default(0)
  commentsCount                Int                             @default(0)
  patchesCount                 Int                             @default(0)
  viewsCount                   Int                             @default(0)
  medias                       CollectionMedia[]               @relation("Collection_to_Media")
  reactions                    CollectionReaction[]
  comments                     CollectionComment[]
  patches                      Patch[]                         @relation("Collection_to_Patch")
  views                        View[]                          @relation("Collection_to_View")
  // Access approvals for private collections
  accesses                     CollectionAccess[]
  
  // Contributions
  contributionRequests         ContributionRequest[]           @relation("CollectionContributionRequests")

  @@index([status, createdAt])
  @@index([status, patchesCount])
  @@index([status, visibility, createdAt])
  @@index([status, pendingCategorySuggestionId]) // PHASE 1: Fast lookup of drafts waiting for category approval
  @@index([ownerId, status, createdAt]) // PHASE 1: User's draft management
}

enum CollectionStatus {
  DRAFT // Created but files not uploaded
  PUBLISHED // Fully published and visible
  ARCHIVED // Hidden from public view
}

enum CollectionVisibility {
  PUBLIC
  PRIVATE
}

enum CollectionType {
  MALE
  FEMALE
  EVERYBODY
}

model CollectionCategory {
  id                      String                          @id @map("_id") @db.Uuid
  slug                    String                          @unique
  name                    String
  description             String?
  isActive                Boolean                         @default(true)
  order                   Int                             @default(0)
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  collections             Collection[]
  // PHASE 1: Approved suggestions that created this category
  approvedSuggestions     CollectionCategorySuggestion[]

  @@index([isActive, order])
}

// ===== Category Suggestions (Phase 6) =====

enum CategorySuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model CollectionCategorySuggestion {
  id                     String                    @id @map("_id") @db.Uuid
  name                   String
  slug                   String                    @unique
  description            String?
  status                 CategorySuggestionStatus  @default(PENDING)
  proposedByUserId       String                    @db.Uuid
  proposedByUser         User                      @relation("ProposedCategorySuggestions", fields: [proposedByUserId], references: [id], onDelete: Cascade)
  decisionByUserId       String?                   @db.Uuid
  decisionByUser         User?                     @relation("DecidedCategorySuggestions", fields: [decisionByUserId], references: [id])
  rejectionReason        String?
  approvedCategoryId     String?                   @db.Uuid
  approvedCategory       CollectionCategory?       @relation(fields: [approvedCategoryId], references: [id])
  decidedAt              DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  // PHASE 1: Relation to draft collections waiting for this suggestion
  pendingCollections     Collection[]

  @@index([status, createdAt])
  @@index([proposedByUserId, createdAt])
  @@index([slug, status]) // PHASE 1: Duplicate detection and fast lookup
}

model CollectionAccess {
  id           String      @id @map("_id") @db.Uuid
  collectionId String      @db.Uuid
  viewerId     String      @db.Uuid
  state        AccessState @default(PENDING)
  grantedBy    String?     @db.Uuid
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  viewer       User        @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([collectionId, viewerId])
  @@index([collectionId, state])
  @@index([viewerId, state])
}

enum AccessState {
  PENDING
  APPROVED
  REVOKED
}

model CollectionMedia {
  id                      String                    @id @map("_id") @db.Uuid
  collectionId            String                    @db.Uuid
  collection              Collection                @relation("Collection_to_Media", fields: [collectionId], references: [id], onDelete: Cascade)
  fileUploadId            String                    @db.Uuid
  file                    FileUpload                @relation("FileUpload_to_CollectionMedia", fields: [fileUploadId], references: [id])
  orderIndex              Int                       @default(0)
  mediaType               FileType
  likesCount              Int                       @default(0)
  CollectionMediaReaction CollectionMediaReaction[]
  commentsCount           Int                       @default(0)
  // inverse relation for cover usage
  coverOf                Collection[]              @relation("CollectionCoverMedia")
}

model CollectionReaction {
  id            String       @id @map("_id") @db.Uuid
  collectionId  String       @db.Uuid
  userId        String       @db.Uuid
  type          ReactionType
  collection    Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId String?
  createdAt     DateTime     @default(now())

  @@unique([collectionId, userId])
  @@index([collectionId])
}

model CollectionComment {
  id           String            @id @map("_id") @db.Uuid
  collectionId String            @db.Uuid
  userId       String            @db.Uuid
  content      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  collection   Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions    CommentReaction[]
}

model CommentReaction {
  id        String            @id @map("_id") @db.Uuid
  commentId String            @db.Uuid
  userId    String            @db.Uuid
  type      ReactionType
  comment   CollectionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@unique([commentId, userId])
}

model Patch {
  id              String     @id @map("_id") @db.Uuid
  collectionId    String     @db.Uuid
  patchingBrandId String     @db.Uuid
  weight          Int        @default(1)
  createdAt       DateTime   @default(now())
  collection      Collection @relation("Collection_to_Patch", fields: [collectionId], references: [id], onDelete: Cascade)
  patchingBrand   User       @relation("UserPatches", fields: [patchingBrandId], references: [id], onDelete: Cascade)
}

model View {
  id           String     @id @map("_id") @db.Uuid
  collectionId String     @db.Uuid
  viewerId     String?    @db.Uuid
  ipHash       String?
  createdAt    DateTime   @default(now())
  collection   Collection @relation("Collection_to_View", fields: [collectionId], references: [id], onDelete: Cascade)
  viewer       User?      @relation(fields: [viewerId], references: [id])

  @@index([collectionId])
}

model Notification {
  id          String           @id @map("_id") @db.Uuid
  recipientId String           @db.Uuid
  actorId     String?          @db.Uuid
  type        NotificationType
  payload     Json?
  html        String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  recipient   User             @relation("UserNotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?            @relation("UserNotificationsActed", fields: [actorId], references: [id])

  @@index([recipientId])
  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
}

model PresignedUpload {
  id           String        @id @map("_id") @db.Uuid
  userId       String        @db.Uuid
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  contentType  String
  fileType     FileType
  s3Key        String        @unique
  size         Int?
  status       PresignStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ===== Likes Analytics & Moderation =====

enum ContentTarget {
  POST
  COLLECTION
}

model DailyLikeAggregate {
  id          String        @id @default(uuid())
  contentId   String
  contentType ContentTarget
  date        DateTime
  count       Int           @default(0)

  @@unique([contentType, contentId, date])
  @@index([contentType, contentId])
}

model QuarantinedLike {
  id          String        @id @default(uuid())
  userId      String
  contentId   String
  contentType ContentTarget
  reason      String?
  createdAt   DateTime      @default(now())

  @@index([userId, contentType, contentId])
}

model CollectionMediaReaction {
  id                String          @id @map("_id") @db.Uuid
  collectionMediaId String          @db.Uuid
  userId            String          @db.Uuid
  type              ReactionType
  media             CollectionMedia @relation(fields: [collectionMediaId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientEventId     String?
  createdAt         DateTime        @default(now())

  @@unique([collectionMediaId, userId])
  @@index([collectionMediaId])
}

// ===== New Social Models =====

enum PatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model BrandPatch {
  id          String      @id @map("_id") @db.Uuid
  requesterId String      @db.Uuid
  receiverId  String      @db.Uuid
  status      PatchStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  requester   User        @relation("SentPatchRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User        @relation("ReceivedPatchRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId, status])
  @@index([receiverId, status])
}

model ContributionRequest {
  id           String      @id @map("_id") @db.Uuid
  requesterId  String      @db.Uuid
  collectionId String      @db.Uuid
  status       PatchStatus @default(PENDING) // Reuse PatchStatus (PENDING, ACCEPTED, REJECTED)
  message      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  requester    User        @relation("UserContributionRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  collection   Collection  @relation("CollectionContributionRequests", fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([requesterId, collectionId])
}

// ... existing models ...

// ===== Brand Dashboard Models =====

model Brand {
  id          String    @id @map("_id") @db.Uuid
  name        String
  ownerId     String    @unique @db.Uuid
  owner       User      @relation("BrandOwner", fields: [ownerId], references: [id])
  
  description String?
  logo        String?
  banner      String?
  
  currency    String    @default("NGN")
  
  orders      Order[]
  payouts     Payout[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id             String        @id @map("_id") @db.Uuid
  brandId        String        @db.Uuid
  brand          Brand         @relation(fields: [brandId], references: [id])
  
  customerName   String
  items          Json          // [{productId, qty, price, thumbnail, name}]
  totalAmount    Decimal       @db.Decimal(10, 2)
  currency       String        @default("NGN")
  
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  @@index([brandId])
  @@index([brandId, status])
}

model Payout {
  id          String       @id @map("_id") @db.Uuid
  brandId     String       @db.Uuid
  brand       Brand        @relation(fields: [brandId], references: [id])
  
  amount      Decimal      @db.Decimal(10, 2)
  currency    String       @default("NGN")
  status      PayoutStatus @default(PENDING)
  reference   String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([brandId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}
