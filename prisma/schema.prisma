// ===== E-Commerce Store Models =====

model Product {
  id              String        @id @map("_id") @db.Uuid
  collectionId    String?       @db.Uuid
  collection      Collection?   @relation("PrimaryCollection", fields: [collectionId], references: [id], onDelete: SetNull)
  brandId         String        @db.Uuid
  brand           Brand         @relation("Brand_to_Products", fields: [brandId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String?       @unique
  description     String?
  currency        String        @default("NGN")
  price           Decimal       @db.Decimal(10, 2)
  salePrice       Decimal?      @db.Decimal(10, 2)
  saleStartAt     DateTime?
  saleEndAt       DateTime?
  
  // Product details
  sku             String?
  weight          Decimal?      @db.Decimal(10, 3)
  weightUnit      String?       @default("kg")
  materials       String?
  careInstructions String?
  costPerItem     Decimal?      @db.Decimal(10, 2)
  
  // Variants
  sizes           String[]      @default([])     // ["XS", "S", "M", "L", "XL", "XXL"]
  sizeStock       Json?                          // {"XS": 5, "S": 10, "M": 0, "L": 8}
  colors          String[]      @default([])     // ["Navy", "Indigo", "Burgundy"]
  colorImages     Json?                          // {"Navy": "url1", "Indigo": "url2"}
  colorHexCodes   Json?                          // {"Navy": "#1E3A5F", "Indigo": "#4F46E5"}
  
  // Media
  images          String[]      @default([])     // Array of image URLs
  thumbnail       String?
  
  // Inventory
  totalStock      Int           @default(0)
  lowStockThreshold Int         @default(5)
  trackInventory  Boolean       @default(true)
  allowBackorders Boolean       @default(false)
  
  // Metadata
  tags            String[]      @default([])
  gender          CollectionType @default(EVERYBODY)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  isPhysicalProduct Boolean     @default(true)
  customsRegion   String?
  
  // Policies
  returnsEligible Boolean       @default(true)
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Scheduling
  publishAt       DateTime?
  publishNotifiedAt DateTime?
  
  // Engagement
  viewsCount      Int           @default(0)
  threadsCount    Int           @default(0) @map("likesCount")
  
  // Soft delete & Archive
  deletedAt       DateTime?
  archivedAt      DateTime?                     // When product was archived
  archiveExpiresAt DateTime?                    // Auto-delete date (60 days from archive)
  archiveLastReminder DateTime?                 // Last 7-day reminder sent
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  variants        ProductVariant[]
  collections     CollectionProduct[]
  
  // Performance indexes
  @@index([brandId])
  @@index([brandId, isActive])
  @@index([collectionId])
  @@index([brandId, isFeatured])
  @@index([createdAt])
  @@index([slug])
  @@index([brandId, createdAt])
  @@index([brandId, price])
  @@index([brandId, viewsCount])
  @@index([isActive, brandId])
  @@index([deletedAt])
}

model ProductVariant {
  id          String   @id @map("_id") @db.Uuid
  productId   String   @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Variant dimensions (nullable to support size-only, color-only, or full size+color)
  size        String?
  color       String?

  // Variant-specific overrides
  sku         String?
  price       Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  colorHex    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, size, color])
  @@index([productId])
  @@index([productId, stock])
}

model IdempotencyKey {
  id           String   @id @map("_id") @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  key          String
  method       String
  path         String
  requestHash  String
  responseBody Json?
  statusCode   Int?

  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([userId, key, method, path])
  @@index([expiresAt])
  @@index([userId, createdAt])
}

model SavedItem {
  id           String        @id @map("_id") @db.Uuid
  userId       String        @db.Uuid
  user         User          @relation("UserSavedItems", fields: [userId], references: [id], onDelete: Cascade)
  targetType   SavedItemType
  targetId     String        @db.Uuid
  createdAt    DateTime      @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt])
  @@index([targetType, targetId])
}

enum SavedItemType {
  COLLECTION
  COLLECTION_MEDIA
}

model CartItem {
  id              String        @id @map("_id") @db.Uuid
  userId          String        @db.Uuid
  productId       String        @db.Uuid
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity        Int           @default(1)
  selectedSize    String?
  selectedColor   String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@unique([userId, productId, selectedSize, selectedColor])
  @@index([userId])
}

model WishlistItem {
  id              String        @id @map("_id") @db.Uuid
  userId          String        @db.Uuid
  productId       String        @db.Uuid
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime      @default(now())
  
  @@unique([userId, productId])
  @@index([userId])
}
