  brand               Brand?             @relation("ReviewBrand", fields: [brandId], references: [id], onDelete: SetNull)
  productId           String?            @db.Uuid
  product             Product?           @relation("ReviewProduct", fields: [productId], references: [id], onDelete: SetNull)
  collectionId        String?            @db.Uuid
  collection          StoreCollection?   @relation("ReviewStoreCollection", fields: [collectionId], references: [id], onDelete: SetNull)
  legacyCollectionId  String?            @db.Uuid
  legacyCollection    Collection?        @relation("ReviewLegacyCollection", fields: [legacyCollectionId], references: [id], onDelete: SetNull)
  designId            String?            @db.Uuid
  design              Design?            @relation("ReviewDesign", fields: [designId], references: [id], onDelete: SetNull)
  orderId             String?            @db.Uuid
  order               Order?             @relation("ReviewOrder", fields: [orderId], references: [id], onDelete: SetNull)
  orderItemId         String?            @db.Uuid
  orderItem           OrderItem?         @relation("ReviewOrderItem", fields: [orderItemId], references: [id], onDelete: SetNull)
  customOrderId       String?            @db.Uuid
  customOrder         CustomOrder?       @relation("ReviewCustomOrder", fields: [customOrderId], references: [id], onDelete: SetNull)
  targetType          ReviewTargetType
  rating              Int
  satisfaction        ReviewSatisfaction
  reviewText          String?
  verifiedPurchase    Boolean            @default(true)
  status              ReviewStatus       @default(APPROVED)
  editWindowExpiresAt DateTime
  editedAt            DateTime?
  deletedAt           DateTime?
  deletedById         String?            @db.Uuid
  deletedBy           User?              @relation("ReviewDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  hiddenReason        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  prompts             ReviewPrompt[]     @relation("ReviewPromptSubmittedReview")

  @@unique([reviewerId, orderItemId, targetType])
  @@unique([reviewerId, customOrderId, targetType])
  @@unique([reviewerId, orderId, brandId, targetType])
  @@index([targetType, status, createdAt])
  @@index([productId, status, createdAt])
  @@index([collectionId, status, createdAt])
  @@index([legacyCollectionId, status, createdAt])
  @@index([designId, status, createdAt])
  @@index([brandId, status, createdAt])
  @@index([reviewerId, createdAt])
  @@map("reviews")
}

model ReviewPrompt {
  id                 String             @id @default(uuid()) @db.Uuid
  buyerId            String             @db.Uuid
  buyer              User               @relation("ReviewPromptBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  brandId            String?            @db.Uuid
  brand              Brand?             @relation("ReviewPromptBrand", fields: [brandId], references: [id], onDelete: SetNull)
  orderId            String?            @db.Uuid
  order              Order?             @relation("ReviewPromptOrder", fields: [orderId], references: [id], onDelete: SetNull)
  orderItemId        String?            @db.Uuid
  orderItem          OrderItem?         @relation("ReviewPromptOrderItem", fields: [orderItemId], references: [id], onDelete: SetNull)
  customOrderId      String?            @db.Uuid
  customOrder        CustomOrder?       @relation("ReviewPromptCustomOrder", fields: [customOrderId], references: [id], onDelete: SetNull)
  productId          String?            @db.Uuid
  product            Product?           @relation("ReviewPromptProduct", fields: [productId], references: [id], onDelete: SetNull)
  collectionId       String?            @db.Uuid
  collection         StoreCollection?   @relation("ReviewPromptStoreCollection", fields: [collectionId], references: [id], onDelete: SetNull)
  legacyCollectionId String?            @db.Uuid
  legacyCollection   Collection?        @relation("ReviewPromptLegacyCollection", fields: [legacyCollectionId], references: [id], onDelete: SetNull)
  designId           String?            @db.Uuid
  design             Design?            @relation("ReviewPromptDesign", fields: [designId], references: [id], onDelete: SetNull)
  targetType         ReviewTargetType
  status             ReviewPromptStatus @default(PENDING)
  shownAt            DateTime?
  skippedAt          DateTime?
  submittedAt        DateTime?
  expiresAt          DateTime?
  submittedReviewId  String?            @db.Uuid
  submittedReview    Review?            @relation("ReviewPromptSubmittedReview", fields: [submittedReviewId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([buyerId, orderItemId, targetType])
  @@unique([buyerId, customOrderId, targetType])
  @@unique([buyerId, orderId, brandId, targetType])
  @@index([buyerId, status, createdAt])
  @@index([targetType, status, createdAt])
  @@index([productId, status, createdAt])
  @@index([collectionId, status, createdAt])
  @@index([legacyCollectionId, status, createdAt])
  @@index([designId, status, createdAt])
  @@index([brandId, status, createdAt])
  @@index([submittedReviewId])
  @@map("review_prompts")
}

