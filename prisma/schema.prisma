model FeatureFlag {
  id          String   @id @map("_id") @db.Uuid
  key         String   @unique
  description String?
  isEnabled   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key, isEnabled])
}

model Dispute {
  id           String             @id @map("_id") @db.Uuid
  type         DisputeType
  reporterId   String             @db.Uuid
  reporter     User               @relation("DisputeReporter", fields: [reporterId], references: [id])
  targetType   String
  targetId     String             @db.Uuid
  description  String
  status       AdminDisputeStatus @default(OPEN)
  resolution   String?
  adminNotes   String?
  assignedToId String?            @db.Uuid
  assignedTo   User?              @relation("DisputeAssignedTo", fields: [assignedToId], references: [id])
  assignedAt   DateTime?
  resolvedById String?            @db.Uuid
  resolvedBy   User?              @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  reopenedAt   DateTime?
  reopenReason String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@index([type, status])
  @@index([assignedToId, status])
}

model PasswordResetToken {
  id        String    @id @map("_id") @db.Uuid
