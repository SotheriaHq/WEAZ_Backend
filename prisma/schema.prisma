// ===== Brand Dashboard Models =====

model Brand {
  id          String    @id @map("_id") @db.Uuid
  name        String
  storeNameLastChangedAt DateTime?
  ownerId     String    @unique @db.Uuid
  owner       User      @relation("BrandOwner", fields: [ownerId], references: [id])
  
  // Store profile fields (store-centric)
  description String?
  tagline     String?
  logo        String?
  banner      String?
  tags        String[]  @default([])
  contactEmail String?
  responseTimeSla String @default("24h")
  
  // Social links
  socialInstagram String?
  socialTwitter   String?
  socialTiktok    String?
  socialWebsite   String?
  
  // Store state
  isStoreOpen Boolean   @default(false)

  currency    String    @default("NGN")

  policy      StorePolicy?

  orders      Order[]
  payouts     Payout[]
  products    Product[] @relation("Brand_to_Products")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StorePolicy {
  id        String   @id @map("_id") @db.Uuid
  brandId   String   @unique @db.Uuid
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  shippingRegions      String[] @default([])
  processingTime       String?
  shippingMethods      String[] @default([])
  freeShippingThreshold Decimal? @db.Decimal(10, 2)
  returnsAccepted      Boolean  @default(true)
  returnWindow         String?
  returnConditions     String[] @default([])
  refundMethod         String?
  responseTimeSla      String   @default("24h")
  sizeChart            Json?
  shippingRules        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
}

model SystemTag {
  id        String   @id @map("_id") @db.Uuid
  tag       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tag])
}

model Tag {
  id             String       @id @map("_id") @db.Uuid
  normalizedName String       @unique
  displayName    String
  usageCount     Int          @default(0)
  isBanned       Boolean      @default(false)
  aliasOfTagId   String?      @db.Uuid
  aliasOfTag     Tag?         @relation("TagAliases", fields: [aliasOfTagId], references: [id], onDelete: SetNull)
  aliases        Tag[]        @relation("TagAliases")
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  bindings       TagBinding[]

  @@index([usageCount(sort: Desc), updatedAt(sort: Desc)])
  @@index([isBanned, usageCount(sort: Desc)])
}

model TagBinding {
  id         String        @id @map("_id") @db.Uuid
  tagId      String        @db.Uuid
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entityType TagEntityType
  entityId   String        @db.Uuid
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([tagId, createdAt(sort: Desc)])
}

model Order {
  id             String        @id @map("_id") @db.Uuid
  brandId        String        @db.Uuid
  brand          Brand         @relation(fields: [brandId], references: [id])
  buyerId        String?       @db.Uuid
  buyer          User?         @relation("OrderBuyer", fields: [buyerId], references: [id])
  
  customerName   String
  shippingAddress Json?
  contactInfo     Json?
  sizeFitSnapshot Json?
  items          Json          // [{productId, qty, price, thumbnail, name}]
  totalAmount    Decimal       @db.Decimal(10, 2)
  currency       String        @default("NGN")
  
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  @@index([brandId])
  @@index([brandId, status])
  @@index([buyerId])
}

model Payout {
  id          String       @id @map("_id") @db.Uuid
  brandId     String       @db.Uuid
  brand       Brand        @relation(fields: [brandId], references: [id])
  
  amount      Decimal      @db.Decimal(10, 2)
  currency    String       @default("NGN")
  status      PayoutStatus @default(PENDING)
  reference   String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([brandId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

