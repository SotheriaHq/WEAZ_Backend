model AdminPermissionGrant {
  id             String   @id @map("_id") @db.Uuid
  userId         String   @db.Uuid
  user           User     @relation("AdminPermissionGrants", fields: [userId], references: [id], onDelete: Cascade)
  permissionCode String
  grantedById    String   @db.Uuid
  grantedBy      User     @relation("AdminPermissionGrantedBy", fields: [grantedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, permissionCode])
  @@index([userId])
}

model AdminAuditLog {
  id            String           @id @map("_id") @db.Uuid
  actorUserId   String           @db.Uuid
  action        AdminAuditAction
  targetType    String?
  targetId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  previousState Json?
  newState      Json?
  createdAt     DateTime         @default(now())

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([action, createdAt])
  @@index([action, ipAddress, userAgent, createdAt])
}

model BreakGlassCode {
  id         String    @id @map("_id") @db.Uuid
  codeHash   String
  validFrom  DateTime
  validUntil DateTime
  usedAt     DateTime?
  usedByIp   String?
  createdAt  DateTime  @default(now())

  @@index([validFrom, validUntil])
}

model BreakGlassRecoveryToken {
  id            String    @id @map("_id") @db.Uuid
  jtiHash       String    @unique
  ipAddress     String?
  userAgentHash String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([expiresAt])
  @@index([usedAt])
}

model AdminSlaConfig {
  id          String    @id @map("_id") @db.Uuid
