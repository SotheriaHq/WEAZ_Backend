  amount      Decimal      @db.Decimal(10, 2)
  currency    String       @default("NGN")
  status      PayoutStatus @default(PENDING)
  reference   String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([brandId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PENDING_SELECTION
  PAYSTACK
  FLUTTERWAVE
  BANK_TRANSFER
  PAY_ON_DELIVERY
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ===== Store Drafts ===== (REMOVED - store setup uses Brand fields directly)

// ===== E-Commerce Store Models =====

model Product {
  id              String        @id @map("_id") @db.Uuid
  collectionId    String?       @db.Uuid
  collection      StoreCollection?   @relation("PrimaryStoreCollection", fields: [collectionId], references: [id], onDelete: SetNull)
  categoryTypeId  String?       @db.Uuid
  categoryType    CollectionCategoryType? @relation(fields: [categoryTypeId], references: [id], onDelete: SetNull)
  categoryId      String?       @db.Uuid
  category        CollectionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId         String        @db.Uuid
  brand           Brand         @relation("Brand_to_Products", fields: [brandId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String?       @unique
  description     String?
  brandNameCache  String?
  searchVector    Unsupported("tsvector")? @map("search_vector")
  currency        String        @default("NGN")
  price           Decimal       @db.Decimal(10, 2)
  salePrice       Decimal?      @db.Decimal(10, 2)
  saleStartAt     DateTime?
  saleEndAt       DateTime?
  
  // Product details
  sku             String?
  weight          Decimal?      @db.Decimal(10, 3)
  weightUnit      String?       @default("kg")
  materials       String?
  careInstructions String?
  costPerItem     Decimal?      @db.Decimal(10, 2)
  
  // Variants
  sizes           String[]      @default([])     // ["XS", "S", "M", "L", "XL", "XXL"]
  sizeStock       Json?                          // {"XS": 5, "S": 10, "M": 0, "L": 8}
  sizingMode      SizingMode    @default(NONE)
  rtwSizeSystem   String?
  rtwSizeType     RtwSizeType?
  rtwLinkedToInventory Boolean   @default(false)
  customGender    Gender?
  customMeasurementKeys String[] @default([])
  customFreeformPointIds String[] @default([])
  fitPreference   FitPreference?
  targetAgeGroup  AgeGroup      @default(ADULT)
  colors          String[]      @default([])     // ["Navy", "Indigo", "Burgundy"]
  colorImages     Json?                          // {"Navy": "url1", "Indigo": "url2"}
  colorHexCodes   Json?                          // {"Navy": "#1E3A5F", "Indigo": "#4F46E5"}
  
  // Media
  images          String[]      @default([])     // Array of image URLs
  thumbnail       String?
  
  // Inventory
  totalStock      Int           @default(0)
  lowStockThreshold Int         @default(5)
  trackInventory  Boolean       @default(true)
  allowBackorders Boolean       @default(false)
  
  // Metadata
  tags            String[]      @default([])
  gender          CollectionType @default(EVERYBODY)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)  // @deprecated — use FeaturedItem table
  isFeaturedBlocked Boolean     @default(false)
  isPhysicalProduct Boolean     @default(true)
  customsRegion   String?
  
  // Policies
  returnsEligible Boolean       @default(true)
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Scheduling
  publishAt       DateTime?
  publishNotifiedAt DateTime?
  
  // Engagement
  viewsCount      Int           @default(0)
  threadsCount    Int           @default(0) @map("likesCount")
  
  // Soft delete & Archive
  deletedAt       DateTime?
  archivedAt      DateTime?                     // When product was archived
  archiveExpiresAt DateTime?                    // Auto-delete date (60 days from archive)
  archiveLastReminder DateTime?                 // Last 7-day reminder sent
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlistItems   WishlistItem[]
  variants        ProductVariant[]
  designCollections CollectionProduct[]
  collections     StoreCollectionProduct[]
  entityFilters   EntityFilter[]  @relation("ProductEntityFilters")
  
  // Performance indexes
  @@index([brandId])
  @@index([brandId, isActive])
  @@index([collectionId])
  @@index([brandId, isFeatured])
  @@index([createdAt])
  @@index([slug])
  @@index([brandId, createdAt])
  @@index([brandId, price])
  @@index([brandId, viewsCount])
  @@index([isActive, brandId])
  @@index([deletedAt])
  @@index([categoryTypeId])
  @@index([categoryId])
}

model ProductVariant {
  id          String   @id @map("_id") @db.Uuid
  productId   String   @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Variant dimensions (nullable to support size-only, color-only, or full size+color)
  size        String?
  color       String?

  // Variant-specific overrides
  sku         String?
  price       Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  colorHex    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, size, color])
  @@index([productId])
  @@index([productId, stock])
}

model IdempotencyKey {
  id           String   @id @map("_id") @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  key          String
  method       String
  path         String
  requestHash  String
  responseBody Json?
  statusCode   Int?

  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([userId, key, method, path])
  @@index([expiresAt])
  @@index([userId, createdAt])
}

model SavedItem {
  id           String        @id @map("_id") @db.Uuid
  userId       String        @db.Uuid
  user         User          @relation("UserSavedItems", fields: [userId], references: [id], onDelete: Cascade)
  targetType   SavedItemType
  targetId     String        @db.Uuid
  createdAt    DateTime      @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt])
  @@index([targetType, targetId])
}

enum SavedItemType {
  COLLECTION
  COLLECTION_MEDIA
}

model CartItem {
  id              String        @id @map("_id") @db.Uuid
  userId          String        @db.Uuid
  productId       String        @db.Uuid
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity        Int           @default(1)
  selectedSize    String?
  selectedColor   String?
  sizingMode      SizingMode    @default(NONE)
  sizeFitData     Json?
  requiredMeasurementKeys String[] @default([])
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@unique([userId, productId, selectedSize, selectedColor])
  @@index([userId])
}

model WishlistItem {
  id              String        @id @map("_id") @db.Uuid
  userId          String        @db.Uuid
  productId       String        @db.Uuid
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime      @default(now())
  
  @@unique([userId, productId])
  @@index([userId])
}

// ===== Structured Filter Dimensions =====

enum FilterEntityType {
  COLLECTION
  STORE_COLLECTION
  PRODUCT
}

model FilterDimension {
  id          String         @id @map("_id") @db.Uuid
  slug        String         @unique
  name        String
  description String?
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  isMulti     Boolean        @default(true)
  appliesTo   String[]       @default(["COLLECTION", "PRODUCT"])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  values      FilterValue[]

  @@index([isActive, order])
}

model FilterValue {
  id            String          @id @map("_id") @db.Uuid
  dimensionId   String          @db.Uuid
  dimension     FilterDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  slug          String
  name          String
  description   String?
  order         Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  entityFilters EntityFilter[]

  @@unique([dimensionId, slug])
  @@index([dimensionId, isActive, order])
}

model EntityFilter {
  id            String           @id @map("_id") @db.Uuid
  filterValueId String           @db.Uuid
  filterValue   FilterValue      @relation(fields: [filterValueId], references: [id], onDelete: Cascade)
  entityType    FilterEntityType
  entityId      String           @db.Uuid
  createdAt     DateTime         @default(now())

  // Optional back-reference for Product direct relation queries
  productId     String?          @db.Uuid
  product       Product?         @relation("ProductEntityFilters", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([filterValueId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([filterValueId])
  @@index([productId])
}

// ===== Featured System =====

model FeaturedItem {
  id              String    @id @map("_id") @db.Uuid
  entityType      String    // "PRODUCT" | "DESIGN"
  entityId        String    @db.Uuid
  brandId         String    @db.Uuid
  brand           Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Time window
  startsAt        DateTime
  expiresAt       DateTime
  isActive        Boolean   @default(true)

  // Admin context
  featuredById    String    @db.Uuid
  featuredBy      User      @relation("FeaturedByAdmin", fields: [featuredById], references: [id])
  removedById     String?   @db.Uuid
  removedBy       User?     @relation("RemovedByAdmin", fields: [removedById], references: [id])
  removedAt       DateTime?
  removeReason    String?   // "MANUAL" | "ITEM_DEACTIVATED" | "ITEM_DELETED" | "BRAND_SUSPENDED" | "EXPIRED"

  // Images — admin selects which images to show
  displayImages   String[]  @default([])
  useCoverOnly    Boolean   @default(true)

  // Performance snapshot (populated on expiry/removal)
  viewsDelta      Int?
  threadsDelta    Int?
  clicksDelta     Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([entityType, entityId, isActive])
  @@index([isActive, expiresAt])
  @@index([brandId, isActive])
  @@index([entityType, isActive])
  @@index([startsAt])
}

