// ====== Comment V2 (unified for posts, collections, and collection media) ======

enum CommentTarget {
  POST
  COLLECTION
  COLLECTION_MEDIA
}

model CommentV2 {
  id               String            @id @map("_id") @db.Uuid
  targetType       CommentTarget
  targetId         String            @db.Uuid
  userId           String            @db.Uuid
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId         String?           @db.Uuid
  parent           CommentV2?        @relation("CommentV2Children", fields: [parentId], references: [id])
  children         CommentV2[]       @relation("CommentV2Children")
  depth            Int               @default(0)
  contentRaw       String
  contentSanitized String
  threadsCount     Int               @default(0) @map("likeCount")
  replyCount       Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  editedAt         DateTime?
  deletedAt        DateTime?
  version          Int               @default(1)
  threads          CommentV2Thread[]

  @@index([targetType, targetId, createdAt])
  @@index([parentId, createdAt])
}

model CommentV2Thread {
  id        String    @id @map("_id") @db.Uuid
  commentId String    @db.Uuid
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  comment   CommentV2 @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("CommentV2Like")
}

model Follow {
  id          String   @id @map("_id") @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  follower    User     @relation("followerFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followingFollows", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Collection {
  id                          String                        @id @map("_id") @db.Uuid
  ownerId                     String                        @db.Uuid
  owner                       User                          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  domain                      CollectionDomain              @default(DESIGN)
  title                       String?
  description                 String?
  searchVector                Unsupported("tsvector")?      @map("search_vector")
  status                      CollectionStatus              @default(DRAFT)
  archivedFromStatus          CollectionStatus?
  visibility                  CollectionVisibility          @default(PUBLIC)
  type                        CollectionType                @default(EVERYBODY)
  categoryId                  String?                       @db.Uuid
  category                    CollectionCategory?           @relation(fields: [categoryId], references: [id])
  categoryTypeId              String?                       @db.Uuid
  categoryType                CollectionCategoryType?       @relation(fields: [categoryTypeId], references: [id], onDelete: SetNull)
  coverMediaId                String?                       @db.Uuid
  coverMedia                  CollectionMedia?              @relation("CollectionCoverMedia", fields: [coverMediaId], references: [id])
  deletedAt                   DateTime?
  deleteExpiresAt             DateTime?
  lastActivityAt              DateTime?
  draftVersion                Int                           @default(0)
  // PHASE 1: Pending category support for draft collections
  pendingCategorySuggestionId String?                       @db.Uuid
  pendingCategorySuggestion   CollectionCategorySuggestion? @relation(fields: [pendingCategorySuggestionId], references: [id], onDelete: SetNull)
  draftReason                 String? // Enum-like: "AWAITING_CATEGORY_APPROVAL", "USER_SAVED", "CATEGORY_REJECTED", "UPLOAD_INCOMPLETE"
  pendingCategoryName         String? // Human-readable name for UI display
  originalSuggestionId        String?                       @db.Uuid // Audit trail - maintains reference even after approval/rejection
  minPrice                    Float?
  maxPrice                    Float?
  isAvailableInStore          Boolean                       @default(false)
  customOrderEnabled          Boolean                       @default(false)
  tags                        String[]                      @default([])
  // Optional sale/discount fields
  saleMinPrice                Float?
  saleMaxPrice                Float?
  saleStartAt                 DateTime?
  saleEndAt                   DateTime?
  sizingMode                  SizingMode                    @default(NONE)
  rtwSizes                    String[]                      @default([])
  rtwSizeSystem               String?
  rtwSizeType                 RtwSizeType?
  customGender                Gender?
  customMeasurementKeys       String[]                      @default([])
  customFreeformPointIds      String[]                      @default([])
  fitPreference               FitPreference?
  targetAgeGroup              AgeGroup                      @default(ADULT)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  metadataEditedAt            DateTime? // Last title/description edit timestamp (30-day cooldown)
  threadsCount                Int                           @default(0) @map("likesCount")
  dislikesCount               Int                           @default(0)
  commentsCount               Int                           @default(0)
  collectionCollabsCount      Int                           @default(0) @map("patchesCount")
  viewsCount                  Int                           @default(0)
  medias                      CollectionMedia[]             @relation("Collection_to_Media")
  reactions                   CollectionReaction[]
  comments                    CollectionComment[]
  collectionCollabs           CollectionCollab[]            @relation("Collection_to_Collab")
  views                       View[]                        @relation("Collection_to_View")
  // Access approvals for private collections
  accesses                    CollectionAccess[]

  // Contributions
  contributionRequests ContributionRequest[] @relation("CollectionContributionRequests")

  // E-commerce products (multi-collection membership)
  // Featured system
  isFeaturedBlocked Boolean @default(false)

  products       CollectionProduct[]
  draftSessions  CollectionDraftSession[]
  bulkUploadJobs CollectionBulkUploadJob[]

  @@index([status, createdAt])
  @@index([status, collectionCollabsCount])
  @@index([status, visibility, createdAt])
  @@index([status, pendingCategorySuggestionId]) // PHASE 1: Fast lookup of drafts waiting for category approval
  @@index([ownerId, status, createdAt]) // PHASE 1: User's draft management
  @@index([ownerId, domain, status, createdAt])
  @@index([categoryTypeId])
  @@index([deletedAt])
  @@index([deleteExpiresAt])
  @@index([lastActivityAt])
}

