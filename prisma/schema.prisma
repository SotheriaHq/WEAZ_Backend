  reporterId    String             @db.Uuid
  reporter      User               @relation("DisputeReporter", fields: [reporterId], references: [id])
  targetType    String
  targetId      String             @db.Uuid
  description   String
  status        AdminDisputeStatus @default(OPEN)
  resolution    String?
  adminNotes    String?
  assignedToId  String?            @db.Uuid
  assignedTo    User?              @relation("DisputeAssignedTo", fields: [assignedToId], references: [id])
  resolvedById  String?            @db.Uuid
  resolvedBy    User?              @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])
