enum AdminEmailChangeStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

model AdminEmailChangeRequest {
  id              String                 @id @map("_id") @db.Uuid
  adminId         String                 @db.Uuid
  admin           User                   @relation("AdminEmailChangeRequests", fields: [adminId], references: [id], onDelete: Cascade)
  currentEmail    String
  newEmail        String
  otpHash         String?
  otpExpiresAt    DateTime?
  otpVerifiedAt   DateTime?
  status          AdminEmailChangeStatus @default(PENDING_VERIFICATION)
  rejectionReason String?
  reviewedById    String?                @db.Uuid
  reviewedBy      User?                  @relation("AdminEmailChangeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([adminId, status])
  @@index([status, createdAt])
  @@map("admin_email_change_requests")
}
