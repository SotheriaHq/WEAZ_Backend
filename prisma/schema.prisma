enum PatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model BrandPatch {
  id          String      @id @map("_id") @db.Uuid
  requesterId String      @db.Uuid
  receiverId  String      @db.Uuid
  status      PatchStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  requester   User        @relation("SentPatchRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User        @relation("ReceivedPatchRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId, status])
  @@index([receiverId, status])
}

model ContributionRequest {
  id           String      @id @map("_id") @db.Uuid
  requesterId  String      @db.Uuid
  collectionId String      @db.Uuid
  status       PatchStatus @default(PENDING) // Reuse PatchStatus (PENDING, ACCEPTED, REJECTED)
  message      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  requester    User        @relation("UserContributionRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  collection   Collection  @relation("CollectionContributionRequests", fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([requesterId, collectionId])
}

