{
  "name": "industri",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "concurrently -k -n BUILD,API \"npm run dev:build\" \"npm run dev:serve\"",
    "dev:build": "nest build --watch",
    "dev:serve": "node scripts/dev-server.cjs",
    "start:dev": "npm run dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node -r module-alias/register dist/main.js",
    "start:worker": "node -r module-alias/register dist/worker.js",
    "dev:worker": "npm run prisma:generate && ts-node -r tsconfig-paths/register src/worker.ts",
    "dev:all": "concurrently -k -n BUILD,API,WORKER \"npm run dev:build\" \"npm run dev:serve\" \"npm run dev:worker\"",
    "dev:reset": "node scripts/reset-all-data.cjs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:perf:messaging": "k6 run ./test/perf/messaging-soak.k6.js",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node prisma/seed.ts",
    "finance:settlement-backfill:audit": "ts-node -r tsconfig-paths/register scripts/audit-settlement-backfill.ts",
    "users:profile-backfill": "ts-node -r tsconfig-paths/register scripts/backfill-user-profiles.ts",
    "brands:profile-backfill": "ts-node -r tsconfig-paths/register scripts/backfill-brand-profiles.ts",
    "brands:profile-backfill:write": "ts-node -r tsconfig-paths/register scripts/backfill-brand-profiles.ts --write",
    "brands:members-backfill": "ts-node -r tsconfig-paths/register scripts/backfill-brand-members.ts",
    "brands:members-backfill:write": "ts-node -r tsconfig-paths/register scripts/backfill-brand-members.ts --write",
    "designs:backfill": "ts-node -r tsconfig-paths/register scripts/backfill-designs-from-legacy-collections.ts --dry-run",
    "designs:backfill:apply": "ts-node -r tsconfig-paths/register scripts/backfill-designs-from-legacy-collections.ts --apply",
    "designs:verify-backfill": "ts-node -r tsconfig-paths/register scripts/verify-design-domain-backfill.ts",
    "catalog-targets:backfill": "ts-node -r tsconfig-paths/register scripts/backfill-catalog-targets.ts --dry-run",
    "catalog-targets:backfill:apply": "ts-node -r tsconfig-paths/register scripts/backfill-catalog-targets.ts --apply",
    "seed:verify": "ts-node -r tsconfig-paths/register scripts/verify-fresh-db-seed.ts",
    "seed:e2e:bagging": "ts-node -r tsconfig-paths/register scripts/seed-bagging-e2e.ts",
    "seed:e2e:reviews": "ts-node -r tsconfig-paths/register scripts/seed-reviews-e2e.ts",
    "seed:phase5c:private-media": "ts-node -r tsconfig-paths/register scripts/seed-phase5c-private-media.ts",
    "smoke:fresh-db-api": "ts-node -r tsconfig-paths/register scripts/smoke-fresh-db-api.ts",
    "seed": "prisma db seed",
    "reset:all": "node scripts/reset-all-data.cjs",
    "check:perf-regressions": "node scripts/check-perf-regressions.cjs"
  },
  "_moduleAliases": {
    "src": "dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-presigned-post": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/cache-manager-redis-store": "^2.0.4",
    "argon2": "^0.43.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.1",
    "bullmq": "^5.76.4",
    "cache-manager": "^7.2.3",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.5.0",
    "expo-server-sdk": "^6.1.0",
    "google-auth-library": "^10.6.2",
    "joi": "^18.0.1",
    "mime-types": "^3.0.1",
    "module-alias": "^2.2.3",
    "nodemailer": "^8.0.7",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.4",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.21",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^7.0.11",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "fast-xml-parser": "^5.7.2",
    "file-type": "^21.3.4",
    "hono": "^4.12.16",
    "lodash": "^4.18.1",
    "socket.io-parser": "^4.2.6",
    "validator": "^13.15.22"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
